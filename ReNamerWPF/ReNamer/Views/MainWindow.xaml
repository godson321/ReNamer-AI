<Window x:Class="ReNamer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReNamer.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" 
        Width="1200" Height="720" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="8"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:IndexConverter x:Key="IndexConverter"/>
        <!-- 状态指示器样式 -->
        <Style x:Key="StateIndicator" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="✓">
                    <Setter Property="Foreground" Value="{StaticResource SemanticSuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="×">
                    <Setter Property="Foreground" Value="{StaticResource SemanticErrorBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="→">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 现代化 ListView 项样式 -->
        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TableColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 工具栏按钮样式 -->
        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarActionButton" TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CommandBar 按钮样式 -->
        <Style x:Key="CommandBarSecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarActionButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CommandBarPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" 
                    CornerRadius="8,8,0,0" Height="40" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 应用图标和标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                        <Path Data="{StaticResource Icon_Rename}" Fill="White" 
                              Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource AppTitle}" 
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="—" Width="46" Height="40" 
                                Click="MinimizeButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0"/>
                        <Button Content="□" Width="46" Height="40" 
                                Click="MaximizeButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0"/>
                        <Button Content="✕" Width="46" Height="40" 
                                Click="CloseButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="Transparent" CornerRadius="0,8,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 菜单栏 -->
            <Menu Grid.Row="1" Background="{StaticResource SurfaceBrush}" Height="32">
                <MenuItem Header="{DynamicResource Menu_File}">
                    <MenuItem Header="{DynamicResource Menu_NewProject}" InputGestureText="Ctrl+N" Command="{Binding CmdNewProject}"/>
                    <MenuItem Header="{DynamicResource Menu_NewInstance}" InputGestureText="Ctrl+Shift+N" Command="{Binding CmdNewInstance}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Undo}" InputGestureText="Ctrl+Shift+Z" Command="{Binding CmdUndoRename}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_AddFiles}" InputGestureText="F3" Command="{Binding CmdAddFiles}"/>
                    <MenuItem Header="{DynamicResource Menu_AddFolders}" InputGestureText="F4" Command="{Binding CmdAddFolders}"/>
                    <MenuItem Header="{DynamicResource Menu_AddPaths}" Command="{Binding CmdAddPaths}"/>
                    <MenuItem Header="{DynamicResource Menu_PasteFiles}" InputGestureText="Ctrl+Shift+V" Command="{Binding CmdPasteFiles}"/>
                    <MenuItem Header="{DynamicResource Menu_Preview}" InputGestureText="F5" Command="{Binding CmdPreview}"/>
                    <MenuItem Header="{DynamicResource Menu_Rename}" InputGestureText="F6" Command="{Binding CmdRename}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Exit}" InputGestureText="Alt+F4" Command="{Binding CmdExit}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Presets}">
                    <MenuItem x:Name="menuLoadPreset" Header="{DynamicResource Menu_LoadPreset}" Command="{Binding CmdLoadPreset}"/>
                    <MenuItem Header="{DynamicResource Menu_SavePresetAs}" InputGestureText="Ctrl+S" Command="{Binding CmdSavePresetAs}"/>
                    <MenuItem Header="{DynamicResource Menu_SavePreset}" InputGestureText="Ctrl+Shift+S" Command="{Binding CmdSavePreset}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_ManagePresets}" InputGestureText="Ctrl+P" Command="{Binding CmdManagePresets}"/>
                    <MenuItem Header="{DynamicResource Menu_BrowsePresetsFolder}" Command="{Binding CmdBrowsePresets}"/>
                    <MenuItem Header="{DynamicResource Menu_ImportPreset}" Command="{Binding CmdImportPreset}"/>
                    <MenuItem Header="{DynamicResource Menu_RescanPresets}" Command="{Binding CmdRescanPresets}"/>
                    <MenuItem Header="{DynamicResource Menu_CreatePresetLinks}" Command="{Binding CmdCreatePresetLinks}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Settings}">
                    <MenuItem Header="{DynamicResource Menu_AllSettings}" InputGestureText="F8" Command="{Binding CmdSettings}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Settings_General}" Command="{Binding CmdSettingsGeneral}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Preview}" Command="{Binding CmdSettingsPreview}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Rename}" Command="{Binding CmdSettingsRename}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_MetaTags}" Command="{Binding CmdSettingsMetaTags}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Misc}" Command="{Binding CmdSettingsMisc}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Filters}" Command="{Binding CmdSettingsFilters}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Help}">
                    <MenuItem Header="{DynamicResource Menu_HelpOnline}" InputGestureText="F1" Command="{Binding CmdHelpOnline}"/>
                    <MenuItem Header="{DynamicResource Menu_QuickGuide}" Command="{Binding CmdQuickGuide}"/>
                    <MenuItem Header="{DynamicResource Menu_UserManual}" Command="{Binding CmdUserManual}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Forum}" Command="{Binding CmdForum}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_LiteVsPro}" Command="{Binding CmdLiteVsPro}"/>
                    <MenuItem Header="{DynamicResource Menu_Purchase}" Command="{Binding CmdPurchase}"/>
                    <MenuItem Header="{DynamicResource Menu_Register}" Command="{Binding CmdRegister}"/>
                    <MenuItem Header="{DynamicResource Menu_Unregister}" Command="{Binding CmdUnregister}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_VersionHistory}" Command="{Binding CmdVersionHistory}"/>
                    <MenuItem Header="{DynamicResource Menu_Copyrights}" Command="{Binding CmdCopyrights}"/>
                    <Separator/>
                    <MenuItem x:Name="menuLanguage" Header="{DynamicResource Menu_Language}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_About}" InputGestureText="Shift+F1" Command="{Binding CmdAbout}"/>
                </MenuItem>
            </Menu>

            <!-- CommandBar（主操作栏）-->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1"
                    Padding="12,6,12,4" MinHeight="56">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Bottom" Height="2" Margin="0,4,0,0"
                            Background="{DynamicResource PrimaryBrush}" Opacity="0.25"
                            CornerRadius="1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 添加文件 -->
                    <Button Command="{Binding CmdAddFiles}" Style="{StaticResource CommandBarSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_AddFile}" Fill="{DynamicResource PrimaryBrush}" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_AddFiles}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- 添加文件夹 -->
                    <Button Command="{Binding CmdAddFolders}" Style="{StaticResource CommandBarSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_AddFolder}" Fill="{DynamicResource SemanticWarningBrush}" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_AddFolders}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    

                    <!-- 预览 -->
                    <Button Command="{Binding CmdPreview}" Style="{StaticResource CommandBarSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Preview}" Fill="{DynamicResource SemanticSuccessBrush}" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_Preview}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    

                    <!-- 重命名（强调按钮）-->
                    <Button Command="{Binding CmdRename}" Style="{StaticResource CommandBarPrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Rename}" Fill="White" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_Rename}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" 
                                       FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="3" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="200" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="150"/>
                </Grid.RowDefinitions>

                <!-- 规则面板（卡片样式）-->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="6,6,6,4" Padding="6">
                    <DockPanel>
                        <!-- 规则工具栏 -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                MinHeight="44" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding CmdAddRule}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Add}" Fill="{StaticResource SemanticSuccessBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Add}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdRemoveRule}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Remove}" Fill="{StaticResource SemanticErrorBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Remove}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                                <Button Command="{Binding CmdMoveRuleUp}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Up}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Up}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdMoveRuleDown}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Down}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Down}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 规则列表 -->
                        <ListView x:Name="lvRules" SelectionMode="Extended"
                                  MouseDoubleClick="Rules_DoubleClick" KeyDown="Rules_KeyDown"
                                  SelectionChanged="Rules_SelectionChanged"
                                  PreviewMouseLeftButtonDown="Rules_PreviewMouseLeftButtonDown"
                                  MouseMove="Rules_MouseMove" Drop="Rules_Drop" DragOver="Rules_DragOver"
                                  AllowDrop="True"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ItemContainerStyle="{StaticResource ModernListViewItem}">
                            <ListView.Resources>
                                <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource TableColumnHeader}"/>
                            </ListView.Resources>
                            <ListView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{DynamicResource CtxRule_Add}" InputGestureText="Ins" Command="{Binding CmdAddRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddAbove}" Command="{Binding CmdRuleAddAbove}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddBelow}" Command="{Binding CmdRuleAddBelow}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Edit}" InputGestureText="Enter" Command="{Binding CmdRuleEdit}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Duplicate}" InputGestureText="Shift+Ins" Command="{Binding CmdRuleDuplicate}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Remove}" InputGestureText="Del" Command="{Binding CmdRemoveRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_RemoveAll}" InputGestureText="Shift+Del" Command="{Binding CmdRuleRemoveAll}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveUp}" InputGestureText="Ctrl+Up" Command="{Binding CmdMoveRuleUp}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveDown}" InputGestureText="Ctrl+Down" Command="{Binding CmdMoveRuleDown}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Menu_ExportClipboard}" Command="{Binding CmdRuleExport}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Comment}" InputGestureText="Shift+Enter" Command="{Binding CmdRuleComment}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_SelectAll}" InputGestureText="Ctrl+A" Command="{Binding CmdRulesSelectAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MarkAll}" InputGestureText="Shift+M" Command="{Binding CmdRulesMarkAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_UnmarkAll}" InputGestureText="Shift+U" Command="{Binding CmdRulesUnmarkAll}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled}" Click="RuleCheckBox_Click"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="#" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Converter={StaticResource IndexConverter}}" 
                                                           HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Rule}" Width="100" 
                                                    DisplayMemberBinding="{Binding RuleName}"/>
                                    <GridViewColumn Header="{DynamicResource Column_Statement}" Width="460" 
                                                    DisplayMemberBinding="{Binding DisplayDescription}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>

                <!-- 分隔器 -->
                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" 
                              Background="Transparent" VerticalAlignment="Center"/>

                <!-- 文件列表面板（卡片样式）-->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="6,4,6,6" Padding="6">
                    <DockPanel>
                        <!-- 文件工具栏 -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                MinHeight="44" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding CmdAddFiles}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_AddFile}" Fill="{StaticResource PrimaryBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Files}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdFilters}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Filter}" Fill="{StaticResource InfoBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Filters}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdOptions}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Options}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdExport}" Style="{StaticResource ToolbarActionButton}">
                                    <TextBlock Text="{DynamicResource Toolbar_Export}" FontSize="13"/>
                                </Button>
                                <Button Command="{Binding CmdAnalyze}" Style="{StaticResource ToolbarActionButton}">
                                    <TextBlock Text="{DynamicResource Toolbar_Analyze}" FontSize="13"/>
                                </Button>
                                <Button x:Name="btnColumns" Command="{Binding CmdColumns}" Style="{StaticResource ToolbarActionButton}">
                                    <TextBlock Text="{DynamicResource Toolbar_Columns}" FontSize="13"/>
                                </Button>
                                <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                                <Button Command="{Binding CmdValidate}" Style="{StaticResource ToolbarActionButton}">
                                    <TextBlock Text="{DynamicResource Toolbar_Validate}" FontSize="13"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 文件列表 -->
                        <ListView x:Name="lvFiles" SelectionMode="Extended" AllowDrop="True"
                                  KeyDown="Files_KeyDown" SelectionChanged="Files_SelectionChanged"
                                  PreviewMouseLeftButtonDown="Files_PreviewMouseLeftButtonDown"
                                  MouseMove="Files_MouseMove" Drop="Files_Drop" DragOver="Files_DragOver"
                                  GridViewColumnHeader.Click="FilesColumnHeader_Click"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ItemContainerStyle="{StaticResource ModernListViewItem}">
                            <ListView.Resources>
                                <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource TableColumnHeader}">
                                    <EventSetter Event="MouseRightButtonUp" Handler="FilesColumnHeader_RightClick"/>
                                    <EventSetter Event="MouseDoubleClick" Handler="FilesColumnHeader_DoubleClick"/>
                                </Style>
                            </ListView.Resources>
                            <ListView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{DynamicResource CtxFile_EditNewName}" InputGestureText="F2" Command="{Binding CmdEditNewName}"/>
                                    <MenuItem Header="{DynamicResource Menu_AnalyzeName}" Command="{Binding CmdAnalyze}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxFile_Shell}">
                                        <MenuItem Header="{DynamicResource CtxFile_OpenFile}" InputGestureText="Enter" Command="{Binding CmdOpenFile}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_OpenFolder}" InputGestureText="Ctrl+Enter" Command="{Binding CmdOpenFolder}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_OpenWithNotepad}" InputGestureText="Shift+Enter" Command="{Binding CmdOpenWithNotepad}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_Properties}" InputGestureText="Alt+Enter" Command="{Binding CmdFileProperties}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_CutToClipboard}" InputGestureText="Ctrl+Shift+X" Command="{Binding CmdCutFiles}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_CopyToClipboard}" InputGestureText="Ctrl+Shift+C" Command="{Binding CmdCopyFiles}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_DeleteRecycle}" Command="{Binding CmdDeleteRecycle}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Mark}">
                                        <MenuItem Header="{DynamicResource CtxFile_MarkItem}" InputGestureText="Shift+M" Command="{Binding CmdMarkSelected}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_UnmarkItem}" InputGestureText="Shift+U" Command="{Binding CmdUnmarkSelected}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_InvertMarking}" InputGestureText="Insert" Command="{Binding CmdInvertMarking}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkChangedIncCase}" Command="{Binding CmdMarkChangedIncCase}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkChangedExcCase}" Command="{Binding CmdMarkChangedExcCase}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkByMask}" Command="{Binding CmdMarkByMask}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkOnlySelected}" Command="{Binding CmdMarkOnlySelected}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Clear}">
                                        <MenuItem Header="{DynamicResource CtxFile_ClearAll}" InputGestureText="Ctrl+Del" Command="{Binding CmdClearAll}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearRenamed}" Command="{Binding CmdClearRenamed}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearFailed}" Command="{Binding CmdClearFailed}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearValid}" Command="{Binding CmdClearValid}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearInvalid}" Command="{Binding CmdClearInvalid}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearNotChanged}" InputGestureText="Ctrl+D" Command="{Binding CmdClearNotChanged}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearMarked}" Command="{Binding CmdClearMarked}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearNotMarked}" Command="{Binding CmdClearNotMarked}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Select}">
                                        <MenuItem Header="{DynamicResource CtxFile_SelectAll}" InputGestureText="Ctrl+A" Command="{Binding CmdFilesSelectAll}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_InvertSelection}" InputGestureText="Ctrl+I" Command="{Binding CmdInvertSelection}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_SelectByNameLength}" InputGestureText="Ctrl+L" Command="{Binding CmdSelectByNameLength}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_SelectByExtension}" InputGestureText="Ctrl+E" Command="{Binding CmdSelectByExtension}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_SelectByMask}" InputGestureText="Ctrl+M" Command="{Binding CmdSelectByMask}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Move}">
                                        <MenuItem Header="{DynamicResource CtxFile_MoveUp}" InputGestureText="Ctrl+Up" Command="{Binding CmdMoveFileUp}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MoveDown}" InputGestureText="Ctrl+Down" Command="{Binding CmdMoveFileDown}"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxFile_RemoveSelected}" InputGestureText="Del" Command="{Binding CmdRemoveSelectedFiles}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="40">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Tag="IsMarked"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsMarked}" Click="FileCheckBox_Click"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="50">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_State}" Tag="State"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding State}" Style="{StaticResource StateIndicator}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Name}" Width="220" 
                                                    DisplayMemberBinding="{Binding OriginalName}"/>
                                    <GridViewColumn Header="{DynamicResource Column_NewName}" Width="220" 
                                                    DisplayMemberBinding="{Binding NewName}"/>
                                    <GridViewColumn Header="{DynamicResource Column_Path}" Width="200" 
                                                    DisplayMemberBinding="{Binding FolderPath}"/>
                                    <GridViewColumn Header="{DynamicResource Column_Extension}" Width="70" 
                                                    DisplayMemberBinding="{Binding Extension}"/>
                                    <GridViewColumn Width="90">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_Size}" Tag="SizeDisplay"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeDisplay}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Error}" Width="150"
                                                    DisplayMemberBinding="{Binding Error}"/>
                                    <!-- Hidden columns (toggled via Columns menu) -->
                                    <GridViewColumn Header="{DynamicResource Column_Folder}" Width="120" 
                                                    DisplayMemberBinding="{Binding FolderName}"/>
                                    <GridViewColumn Header="{DynamicResource Column_NewPath}" Width="200" 
                                                    DisplayMemberBinding="{Binding NewPath}"/>
                                    <GridViewColumn Width="90">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_SizeKB}" Tag="SizeKB"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeKB}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="90">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_SizeMB}" Tag="SizeMB"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeMB}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Created}" Width="140" 
                                                    DisplayMemberBinding="{Binding CreatedDisplay}"/>
                                    <GridViewColumn Header="{DynamicResource Column_Modified}" Width="140" 
                                                    DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                                    <GridViewColumn Header="{DynamicResource Column_ExifDate}" Width="140"
                                                    DisplayMemberBinding="{Binding ExifDateDisplay}"/>
                                    <GridViewColumn Width="80">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_NameDigits}" Tag="NameDigits"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NameDigits}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_PathDigits}" Width="80" 
                                                    DisplayMemberBinding="{Binding PathDigits}"/>
                                    <GridViewColumn Width="80">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_NameLength}" Tag="NameLength"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NameLength}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="100">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_NewNameLength}" Tag="NewNameLength"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NewNameLength}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="80">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_PathLength}" Tag="PathLength"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PathLength}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="100">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="{DynamicResource Column_NewPathLength}" Tag="NewPathLength"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NewPathLength}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_OldPath}" Width="200" 
                                                    DisplayMemberBinding="{Binding OldPath}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Height="32" Padding="16,0" CornerRadius="0,0,8,8"
                    MouseMove="StatusBar_MouseMove" MouseLeftButtonUp="StatusBar_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="tbStatusProgress" Grid.Column="0"
                               Text="{DynamicResource Status_Ready}" 
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <ProgressBar x:Name="pbProgress" Grid.Column="1" Height="14" Margin="8,0"
                                 VerticalAlignment="Center" Minimum="0" Maximum="100" Value="0"
                                 Visibility="Collapsed"/>

                    <TextBlock x:Name="tbStatusFiles" Grid.Column="2"
                               Text="{DynamicResource Status_FilesSummary}" 
                               VerticalAlignment="Center" FontSize="13" Margin="8,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock x:Name="tbStatusInfo" Grid.Column="3"
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
