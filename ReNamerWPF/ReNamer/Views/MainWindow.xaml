<Window x:Class="ReNamer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReNamer.Views"
        xmlns:fileList="clr-namespace:ReNamer.Views.FileList"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" 
        Icon="/Resources/AppIcon.ico"
        Width="600" Height="700" MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="8"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:IndexConverter x:Key="IndexConverter"/>
        <local:CollectionIndexConverter x:Key="CollectionIndexConverter"/>
        <local:RuleDropPreviewVisibilityConverter x:Key="RuleDropPreviewVisibilityConverter"/>
        <local:RuleDropPreviewVerticalAlignmentConverter x:Key="RuleDropPreviewVerticalAlignmentConverter"/>
        <!-- 状态指示器样式 -->
        <Style x:Key="StateIndicator" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="✓">
                    <Setter Property="Foreground" Value="{StaticResource SemanticSuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="×">
                    <Setter Property="Foreground" Value="{StaticResource SemanticErrorBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="→">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 现代化 ListView 项样式 -->
        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TableColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="EnterpriseRuleColumnHeader" TargetType="GridViewColumnHeader" BasedOn="{StaticResource TableColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="CompactRuleUtilityColumnHeader" TargetType="GridViewColumnHeader" BasedOn="{StaticResource EnterpriseRuleColumnHeader}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="EnterpriseRuleListViewItem" TargetType="ListViewItem" BasedOn="{StaticResource ModernListViewItem}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EnterpriseRuleCellBorder" TargetType="Border">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Background}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="RuleDragHandleStyle" TargetType="Border">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeAll"/>
            <Setter Property="ToolTip" Value="{DynamicResource Rules_DragHint}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ClassicRuleTableHeaderCell" TargetType="Border">
            <Setter Property="Background" Value="#FFECEFF3"/>
            <Setter Property="BorderBrush" Value="#FFC5CED8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="ClassicRuleTableHeaderLastCell" TargetType="Border" BasedOn="{StaticResource ClassicRuleTableHeaderCell}">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="ClassicRuleTableRowItem" TargetType="ListViewItem" BasedOn="{StaticResource ModernListViewItem}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF7FAFD"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFEAF2FF"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ClassicRuleTableCell" TargetType="Border">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#FFD6DEE8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Background}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="ClassicRuleTableUtilityCell" TargetType="Border" BasedOn="{StaticResource ClassicRuleTableCell}">
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="ClassicRuleTableLastCell" TargetType="Border" BasedOn="{StaticResource ClassicRuleTableCell}">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="ClassicRuleHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF2A313A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RuleColumnResizeThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RuleDragHandleThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="SizeAll"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="Transparent">
                            <UniformGrid Rows="3" Columns="2"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                            </UniformGrid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="ClassicRuleListItemTemplate">
            <Grid HorizontalAlignment="Stretch" SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleDragColumnWidth}"/>
                    <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleCheckColumnWidth}"/>
                    <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleIndexColumnWidth}"/>
                    <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleNameColumnWidth}"/>
                    <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleDescriptionColumnWidth}"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ClassicRuleTableUtilityCell}">
                    <Thumb Style="{StaticResource RuleDragHandleThumbStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           PreviewMouseLeftButtonDown="Rules_PreviewMouseLeftButtonDown"
                           PreviewMouseLeftButtonUp="RuleDragHandle_PreviewMouseLeftButtonUp"
                           PreviewMouseMove="Rules_MouseMove"/>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource ClassicRuleTableUtilityCell}">
                    <CheckBox IsChecked="{Binding IsEnabled}"
                              Click="RuleCheckBox_Click"
                              Cursor="Arrow"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource ClassicRuleTableCell}">
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource IndexConverter}}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource ClassicRuleTableCell}">
                    <TextBlock Text="{Binding LocalizedRuleName}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource ClassicRuleTableLastCell}">
                    <TextBlock Text="{Binding LocalizedDisplayDescription}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding LocalizedDisplayDescription}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <Style x:Key="EnterpriseDataGrid" TargetType="{x:Type DataGrid}">
            <Setter Property="RowHeight" Value="24"/>
            <Setter Property="ColumnHeaderHeight" Value="30"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="EnterpriseDataGridColumnHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  Margin="8,0,8,0"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock x:Name="SortArrow"
                                           Grid.Column="1"
                                           Margin="4,0,8,0"
                                           VerticalAlignment="Center"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{TemplateBinding Foreground}"
                                           Visibility="Collapsed"
                                           Text="▲"/>
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       Width="12"
                                       Margin="0,-1,-1,-1"
                                       Cursor="SizeWE"
                                       Background="Transparent">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Text" Value="▲"/>
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Text" Value="▼"/>
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Ascending">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Descending">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EnterpriseDataGridRow" TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="False"/>
                        <Condition Property="fileList:LogicalSelectionHelper.IsLogicalSelected" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                        <Condition Property="fileList:LogicalSelectionHelper.IsLogicalSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EnterpriseDataGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(fileList:LogicalSelectionHelper.IsLogicalSelected)}" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </DataTrigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#CCF7D047"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="#1AF7D047"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#FFE7B900"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="#33F7D047"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RuleTableDataGrid" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource EnterpriseDataGrid}">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="RowBackground" Value="#FFFFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFFFFFF"/>
        </Style>

        <Style x:Key="RuleTableDataGridRow" TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource EnterpriseDataGridRow}">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style x:Key="RuleTableDataGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Grid SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <Border Background="{TemplateBinding Background}"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            <Border Height="2"
                                    Margin="0,-1,0,-1"
                                    Background="{DynamicResource PrimaryBrush}"
                                    IsHitTestVisible="False">
                                <Border.Visibility>
                                    <MultiBinding Converter="{StaticResource RuleDropPreviewVisibilityConverter}">
                                        <Binding/>
                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="RuleDropPreviewTarget"/>
                                    </MultiBinding>
                                </Border.Visibility>
                                <Border.VerticalAlignment>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                             Path="RuleDropPreviewInsertAfter"
                                             Converter="{StaticResource RuleDropPreviewVerticalAlignmentConverter}"/>
                                </Border.VerticalAlignment>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 工具栏按钮样式 -->
        <Style x:Key="FileDragHandleStyle" TargetType="Border" BasedOn="{StaticResource RuleDragHandleStyle}">
            <Setter Property="ToolTip" Value="{x:Null}"/>
        </Style>

        <Style x:Key="FileTableDataGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Grid SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            <Border Height="2"
                                    Margin="0,-1,0,-1"
                                    Background="{DynamicResource PrimaryBrush}"
                                    IsHitTestVisible="False">
                                <Border.Visibility>
                                    <MultiBinding Converter="{StaticResource RuleDropPreviewVisibilityConverter}">
                                        <Binding/>
                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="FileDropPreviewTarget"/>
                                    </MultiBinding>
                                </Border.Visibility>
                                <Border.VerticalAlignment>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                             Path="FileDropPreviewInsertAfter"
                                             Converter="{StaticResource RuleDropPreviewVerticalAlignmentConverter}"/>
                                </Border.VerticalAlignment>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(fileList:LogicalSelectionHelper.IsLogicalSelected)}" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </DataTrigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#CCF7D047"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="#1AF7D047"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#FFE7B900"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="#33F7D047"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarActionButton" TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CommandBar 按钮样式 -->
        <Style x:Key="CommandBarSecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarActionButton}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CommandBarPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="FileToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarActionButton}">
            <Setter Property="Width" Value="74"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CmdPreview}"/>
    </Window.InputBindings>

    <Border x:Name="WindowRootBorder"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border x:Name="TitleBarBorder"
                    Grid.Row="0" Background="{StaticResource PrimaryBrush}" 
                    CornerRadius="8,8,0,0" Height="36"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseRightButtonUp="TitleBar_MouseRightButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 应用图标和标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0">
                        <Path x:Name="TitleBarIcon"
                              Data="{StaticResource Icon_Rename}" Fill="White" 
                              Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleBarText"
                                   Text="{DynamicResource AppTitle}" 
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="—" Width="42" Height="36" 
                                Click="MinimizeButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0"/>
                        <Button Content="□" Width="42" Height="36" 
                                Click="MaximizeButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0"/>
                        <Button Content="✕" Width="42" Height="36" 
                                Click="CloseButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="Transparent" CornerRadius="0,8,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 菜单栏 -->
            <Menu Grid.Row="1" Background="{StaticResource SurfaceBrush}" Height="30">
                <MenuItem Header="{DynamicResource Menu_File}">
                    <MenuItem Header="{DynamicResource Menu_Undo}" Command="{Binding CmdUndoRename}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_AddFiles}" Command="{Binding CmdAddFiles}"/>
                    <MenuItem Header="{DynamicResource Menu_AddFolders}" Command="{Binding CmdAddFolders}"/>
                    <MenuItem Header="{DynamicResource Menu_AddPaths}" Command="{Binding CmdAddPaths}"/>
                    <MenuItem Header="{DynamicResource Menu_PasteFiles}" Command="{Binding CmdPasteFiles}"/>
                    <MenuItem Header="{DynamicResource Menu_Rename}" Command="{Binding CmdRename}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Exit}" Command="{Binding CmdExit}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Presets}">
                    <MenuItem x:Name="menuLoadPreset" Header="{DynamicResource Menu_LoadPreset}" Command="{Binding CmdLoadPreset}"/>
                    <MenuItem Header="{DynamicResource Menu_SavePresetAs}" Command="{Binding CmdSavePresetAs}"/>
                    <MenuItem Header="{DynamicResource Menu_SavePreset}" Command="{Binding CmdSavePreset}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_ManagePresets}" Command="{Binding CmdManagePresets}"/>
                    <MenuItem Header="{DynamicResource Menu_BrowsePresetsFolder}" Command="{Binding CmdBrowsePresets}"/>
                    <MenuItem Header="{DynamicResource Menu_RescanPresets}" Command="{Binding CmdRescanPresets}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Settings}">
                    <MenuItem Header="{DynamicResource Menu_AllSettings}" Command="{Binding CmdSettings}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Settings_General}" Command="{Binding CmdSettingsGeneral}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Preview}" Command="{Binding CmdSettingsPreview}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Rename}" Command="{Binding CmdSettingsRename}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_MetaTags}" Command="{Binding CmdSettingsMetaTags}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Misc}" Command="{Binding CmdSettingsMisc}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Filters}" Command="{Binding CmdSettingsFilters}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Help}">
                    <MenuItem x:Name="menuLanguage" Header="{DynamicResource Menu_Language}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_About}" Command="{Binding CmdAbout}"/>
                    <Separator/>
                    <MenuItem Header="Debug: Clipboard Test" Click="DebugWindow_Click"/>
                </MenuItem>
            </Menu>

            <!-- CommandBar（主操作栏）-->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1"
                    Padding="10,4,10,3" MinHeight="50">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Bottom" Height="2" Margin="0,4,0,0"
                            Background="{DynamicResource PrimaryBrush}" Opacity="0.25"
                            CornerRadius="1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 添加文件 -->
                        <Button Command="{Binding CmdAddFiles}" Style="{StaticResource CommandBarSecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_AddFile}" Fill="{DynamicResource PrimaryBrush}" 
                                  Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Toolbar_AddFiles}" 
                                       VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <!-- 添加文件夹 -->
                        <Button Command="{Binding CmdAddFolders}" Style="{StaticResource CommandBarSecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_AddFolder}" Fill="{DynamicResource SemanticWarningBrush}" 
                                  Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Toolbar_AddFolders}" 
                                       VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Button>



                        <!-- 预览 -->
                        <!-- 重命名（强调按钮）-->
                        <Button Command="{Binding CmdRename}" Style="{StaticResource CommandBarSecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Rename}" Fill="{DynamicResource PrimaryBrush}" 
                                  Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Toolbar_Rename}" 
                                       VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="3" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="188" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="150"/>
                </Grid.RowDefinitions>

                <!-- 规则面板（卡片样式）-->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="4,4,4,3" Padding="4">
                    <DockPanel>
                        <!-- 规则工具栏 -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                MinHeight="34" Padding="6,3">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding CmdAddRule}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Add}" Fill="{StaticResource SemanticSuccessBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Add}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdRemoveRule}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Remove}" Fill="{StaticResource SemanticErrorBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Remove}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdMoveRuleUp}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Up}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Up}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdMoveRuleDown}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Down}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Down}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 规则列表 -->
                        <DataGrid x:Name="lvRules"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="True"
                                  CanUserSortColumns="False"
                                  HeadersVisibility="Column"
                                  MouseDoubleClick="Rules_DoubleClick"
                                  SelectionChanged="Rules_SelectionChanged"
                                  Drop="Rules_Drop"
                                  DragOver="Rules_DragOver"
                                  DragLeave="Rules_DragLeave"
                                  AllowDrop="True"
                                  ToolTip="{DynamicResource Rules_DragHint}"
                                  AlternationCount="2147483647"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  Style="{StaticResource RuleTableDataGrid}"
                                  RowStyle="{StaticResource RuleTableDataGridRow}"
                                  CellStyle="{StaticResource RuleTableDataGridCell}">
                            <DataGrid.Resources>
                                <Style x:Key="CenteredRuleCheckBox" TargetType="{x:Type CheckBox}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                                <Style x:Key="RuleCellText" TargetType="{x:Type TextBlock}">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                                <Style x:Key="RuleNameCellText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource RuleCellText}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource EnterpriseDataGridColumnHeader}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding CmdRemoveRule}"/>
                                <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding CmdRulesSelectAll}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{DynamicResource CtxRule_Add}" Command="{Binding CmdAddRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddAbove}" Command="{Binding CmdRuleAddAbove}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddBelow}" Command="{Binding CmdRuleAddBelow}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Edit}" Command="{Binding CmdRuleEdit}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Duplicate}" Command="{Binding CmdRuleDuplicate}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Remove}" Command="{Binding CmdRemoveRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_RemoveAll}" Command="{Binding CmdRuleRemoveAll}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveUp}" Command="{Binding CmdMoveRuleUp}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveDown}" Command="{Binding CmdMoveRuleDown}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Menu_ExportClipboard}" Command="{Binding CmdRuleExport}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Comment}" Command="{Binding CmdRuleComment}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_SelectAll}" InputGestureText="Ctrl+A" Command="{Binding CmdRulesSelectAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MarkAll}" Command="{Binding CmdRulesMarkAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_UnmarkAll}" Command="{Binding CmdRulesUnmarkAll}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="34" CanUserSort="False">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource RuleTableDataGridCell}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RuleDragHandleStyle}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    PreviewMouseLeftButtonDown="Rules_PreviewMouseLeftButtonDown"
                                                    PreviewMouseLeftButtonUp="RuleDragHandle_PreviewMouseLeftButtonUp"
                                                    MouseMove="Rules_MouseMove">
                                                <UniformGrid Rows="3"
                                                             Columns="2"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                    <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                    <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                    <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                    <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                    <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                    <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                </UniformGrid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="46" CanUserSort="False">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource RuleTableDataGridCell}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredRuleCheckBox}"
                                                      IsChecked="{Binding IsEnabled}"
                                                      Click="RuleCheckBox_Click"
                                                      Cursor="Arrow"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="#" Width="50" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource RuleCellText}"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource CollectionIndexConverter}">
                                                        <Binding/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="Rules"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="RuleOrderVersion"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource Column_Rule}"
                                                    Width="170"
                                                    Binding="{Binding LocalizedRuleName}"
                                                    ElementStyle="{StaticResource RuleNameCellText}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Statement}"
                                                    Width="*"
                                                    Binding="{Binding LocalizedDisplayDescription}"
                                                    ElementStyle="{StaticResource RuleCellText}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Visibility="Collapsed"
                                Background="{DynamicResource BackgroundBrush}"
                                BorderBrush="#FFC5CED8"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0"
                                      Background="#FFECEFF3"
                                      SnapsToDevicePixels="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleDragColumnWidth}"/>
                                        <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleCheckColumnWidth}"/>
                                        <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleIndexColumnWidth}"/>
                                        <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleNameColumnWidth}"/>
                                        <ColumnDefinition Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RuleDescriptionColumnWidth}"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource ClassicRuleTableHeaderCell}">
                                        <Thumb Style="{StaticResource RuleColumnResizeThumbStyle}"
                                               Tag="drag"
                                               DragDelta="RulesHeaderResizeThumb_DragDelta"/>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource ClassicRuleTableHeaderCell}">
                                        <Thumb Style="{StaticResource RuleColumnResizeThumbStyle}"
                                               Tag="check"
                                               DragDelta="RulesHeaderResizeThumb_DragDelta"/>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource ClassicRuleTableHeaderCell}">
                                        <Grid>
                                            <TextBlock Text="#" Style="{StaticResource ClassicRuleHeaderText}" HorizontalAlignment="Center"/>
                                            <Thumb Style="{StaticResource RuleColumnResizeThumbStyle}"
                                                   Tag="index"
                                                   DragDelta="RulesHeaderResizeThumb_DragDelta"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource ClassicRuleTableHeaderCell}">
                                        <Grid>
                                            <TextBlock Text="{DynamicResource Column_Rule}" Style="{StaticResource ClassicRuleHeaderText}"/>
                                            <Thumb Style="{StaticResource RuleColumnResizeThumbStyle}"
                                                   Tag="rule"
                                                   DragDelta="RulesHeaderResizeThumb_DragDelta"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource ClassicRuleTableHeaderLastCell}">
                                        <TextBlock Text="{DynamicResource Column_Statement}" Style="{StaticResource ClassicRuleHeaderText}"/>
                                    </Border>
                                </Grid>

                                <ListView x:Name="lvRulesLegacy"
                                          Grid.Row="1"
                                          SelectionMode="Extended"
                                          MouseDoubleClick="Rules_DoubleClick"
                                          SelectionChanged="Rules_SelectionChanged"
                                          Drop="Rules_Drop"
                                          DragOver="Rules_DragOver"
                                          AllowDrop="True"
                                          ToolTip="{DynamicResource Rules_DragHint}"
                                          AlternationCount="2147483647"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          Background="{DynamicResource BackgroundBrush}"
                                          BorderThickness="0"
                                          Padding="0">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem" BasedOn="{StaticResource ClassicRuleTableRowItem}"/>
                                    </ListView.ItemContainerStyle>
                            <ListView.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding CmdRemoveRule}"/>
                                <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding CmdRulesSelectAll}"/>
                            </ListView.InputBindings>
                            <ListView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{DynamicResource CtxRule_Add}" Command="{Binding CmdAddRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddAbove}" Command="{Binding CmdRuleAddAbove}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddBelow}" Command="{Binding CmdRuleAddBelow}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Edit}" Command="{Binding CmdRuleEdit}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Duplicate}" Command="{Binding CmdRuleDuplicate}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Remove}" Command="{Binding CmdRemoveRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_RemoveAll}" Command="{Binding CmdRuleRemoveAll}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveUp}" Command="{Binding CmdMoveRuleUp}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveDown}" Command="{Binding CmdMoveRuleDown}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Menu_ExportClipboard}" Command="{Binding CmdRuleExport}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Comment}" Command="{Binding CmdRuleComment}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_SelectAll}" InputGestureText="Ctrl+A" Command="{Binding CmdRulesSelectAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MarkAll}" Command="{Binding CmdRulesMarkAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_UnmarkAll}" Command="{Binding CmdRulesUnmarkAll}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="34" Header="">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ClassicRuleTableUtilityCell}">
                                                    <Border Style="{StaticResource RuleDragHandleStyle}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            PreviewMouseLeftButtonDown="Rules_PreviewMouseLeftButtonDown"
                                                            PreviewMouseLeftButtonUp="RuleDragHandle_PreviewMouseLeftButtonUp"
                                                            MouseMove="Rules_MouseMove">
                                                        <TextBlock Text="⋮⋮"
                                                                   FontFamily="Segoe UI Symbol"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Opacity="0.82"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="46" Header="">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ClassicRuleTableUtilityCell}">
                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              Click="RuleCheckBox_Click"
                                                              Cursor="Arrow"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="#" Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ClassicRuleTableCell}">
                                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource IndexConverter}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Rule}" Width="170">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ClassicRuleTableCell}">
                                                    <TextBlock Text="{Binding LocalizedRuleName}"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Statement}" Width="440">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ClassicRuleTableLastCell}">
                                                    <TextBlock Text="{Binding LocalizedDisplayDescription}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding LocalizedDisplayDescription}"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- 分隔器 -->
                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" 
                              Background="Transparent" VerticalAlignment="Center"/>

                <!-- 文件列表面板（卡片样式）-->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="4,3,4,4" Padding="4">
                    <DockPanel>
                        <!-- 文件工具栏 -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                MinHeight="34" Padding="6,3">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding CmdClearAll}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Remove}" Fill="{StaticResource SemanticErrorBrush}"
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Clear}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdFilters}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Filter}" Fill="{StaticResource InfoBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Filters}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdOptions}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Options}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdAnalyze}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Analyze}" Fill="{StaticResource PrimaryBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Analyze}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdValidate}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Check}" Fill="{StaticResource SemanticSuccessBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Validate}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdPreview}" Style="{StaticResource FileToolbarButton}" ToolTip="F5">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Refresh}" Fill="{StaticResource InfoBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Refresh}" Margin="6,0,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 文件列表 -->
                        <Grid x:Name="FileListHost">
                            <DataGrid x:Name="lvFiles" SelectionMode="Extended" SelectionUnit="FullRow" AllowDrop="True"
                                  PreviewMouseLeftButtonDown="Files_PreviewMouseLeftButtonDown"
                                  MouseDoubleClick="Files_MouseDoubleClick"
                                  MouseMove="Files_MouseMove" Drop="Files_Drop" DragOver="Files_DragOver"
                                  Sorting="FilesColumnHeader_Click"
                                  Style="{StaticResource EnterpriseDataGrid}"
                                  RowStyle="{StaticResource EnterpriseDataGridRow}"
                                  CellStyle="{StaticResource FileTableDataGridCell}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                    <Style x:Key="CenteredCellText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style x:Key="ChangedNewNameText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredCellText}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasChanged}" Value="True">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasChanged}" Value="True"/>
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(fileList:LogicalSelectionHelper.IsLogicalSelected)}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="RightAlignedCellText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredCellText}">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                    <Style x:Key="CenteredEditingCellTextBox" TargetType="{x:Type TextBox}">
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                    </Style>
                                    <Style x:Key="CenteredFileCheckBox" TargetType="{x:Type CheckBox}">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource EnterpriseDataGridColumnHeader}">
                                        <EventSetter Event="MouseRightButtonUp" Handler="FilesColumnHeader_RightClick"/>
                                        <EventSetter Event="MouseDoubleClick" Handler="FilesColumnHeader_DoubleClick"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding CmdRemoveSelectedFiles}"/>
                                    <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding CmdFilesSelectAll}"/>
                                    <KeyBinding Key="F5" Command="{Binding CmdPreview}"/>
                                </DataGrid.InputBindings>
                                <DataGrid.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{DynamicResource CtxFile_EditNewName}" Command="{Binding CmdEditNewName}"/>
                                        <MenuItem Header="{DynamicResource Menu_AnalyzeName}" Command="{Binding CmdAnalyze}"/>
                                        <MenuItem Header="{DynamicResource Toolbar_Refresh}" InputGestureText="F5" Command="{Binding CmdPreview}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_Shell}">
                                            <MenuItem Header="{DynamicResource CtxFile_OpenFile}" Command="{Binding CmdOpenFile}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_OpenFolder}" Command="{Binding CmdOpenFolder}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_OpenWithNotepad}" Command="{Binding CmdOpenWithNotepad}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_Properties}" Command="{Binding CmdFileProperties}"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource CtxFile_CutToClipboard}" Command="{Binding CmdCutFiles}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_CopyToClipboard}" Command="{Binding CmdCopyFiles}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_DeleteRecycle}" Command="{Binding CmdDeleteRecycle}"/>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource CtxFile_Mark}">
                                            <MenuItem Header="{DynamicResource CtxFile_MarkItem}" Command="{Binding CmdMarkSelected}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_UnmarkItem}" Command="{Binding CmdUnmarkSelected}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_InvertMarking}" Command="{Binding CmdInvertMarking}"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource CtxFile_MarkChangedIncCase}" Command="{Binding CmdMarkChangedIncCase}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_MarkChangedExcCase}" Command="{Binding CmdMarkChangedExcCase}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_MarkByMask}" Command="{Binding CmdMarkByMask}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_MarkOnlySelected}" Command="{Binding CmdMarkOnlySelected}"/>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource CtxFile_Clear}">
                                            <MenuItem Header="{DynamicResource CtxFile_ClearAll}" Command="{Binding CmdClearAll}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearRenamed}" Command="{Binding CmdClearRenamed}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearFailed}" Command="{Binding CmdClearFailed}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearValid}" Command="{Binding CmdClearValid}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearInvalid}" Command="{Binding CmdClearInvalid}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearNotChanged}" Command="{Binding CmdClearNotChanged}"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearMarked}" Command="{Binding CmdClearMarked}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_ClearNotMarked}" Command="{Binding CmdClearNotMarked}"/>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource CtxFile_Select}">
                                            <MenuItem Header="{DynamicResource CtxFile_SelectAll}" InputGestureText="Ctrl+A" Command="{Binding CmdFilesSelectAll}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_InvertSelection}" Command="{Binding CmdInvertSelection}"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource CtxFile_SelectByNameLength}" Command="{Binding CmdSelectByNameLength}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_SelectByExtension}" Command="{Binding CmdSelectByExtension}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_SelectByMask}" Command="{Binding CmdSelectByMask}"/>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource CtxFile_Move}">
                                            <MenuItem Header="{DynamicResource CtxFile_MoveUp}" Command="{Binding CmdMoveFileUp}"/>
                                            <MenuItem Header="{DynamicResource CtxFile_MoveDown}" Command="{Binding CmdMoveFileDown}"/>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_RemoveSelected}" InputGestureText="Del" Command="{Binding CmdRemoveSelectedFiles}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="34" SortMemberPath="FileReorder" CanUserSort="False">
                                        <DataGridTemplateColumn.CellStyle>
                                            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource FileTableDataGridCell}">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTemplateColumn.CellStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileDragHandleStyle}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        PreviewMouseLeftButtonDown="Files_PreviewMouseLeftButtonDown"
                                                        PreviewMouseLeftButtonUp="FileDragHandle_PreviewMouseLeftButtonUp"
                                                        MouseMove="Files_MouseMove">
                                                    <UniformGrid Rows="3"
                                                                 Columns="2"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center">
                                                        <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                        <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                        <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                        <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                        <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                        <Ellipse Width="2.5" Height="2.5" Fill="#FF8894A3" Margin="1"/>
                                                    </UniformGrid>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="44" SortMemberPath="IsMarked">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox Style="{StaticResource CenteredFileCheckBox}"
                                                      Click="FileHeaderCheckBox_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellStyle>
                                            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource FileTableDataGridCell}">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTemplateColumn.CellStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox Style="{StaticResource CenteredFileCheckBox}"
                                                      IsChecked="{Binding IsMarked}"
                                                      Click="FileCheckBox_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="{DynamicResource Column_State}" Width="60" SortMemberPath="State">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding State}" Style="{StaticResource StateIndicator}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn x:Name="colFileName" Header="{DynamicResource Column_Name}" Width="150" Binding="{Binding OriginalName}" SortMemberPath="OriginalName" IsReadOnly="True" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                    <DataGridTextColumn x:Name="colNewName" Header="{DynamicResource Column_NewName}" Width="150" Binding="{Binding NewName}" SortMemberPath="NewName" ElementStyle="{StaticResource ChangedNewNameText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Path}" Width="200" Binding="{Binding FolderPath}" SortMemberPath="FolderPath" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Extension}" Width="70" Binding="{Binding Extension}" SortMemberPath="Extension" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Size}" Width="90" Binding="{Binding SizeDisplay}" SortMemberPath="Size" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Error}" Width="150" Binding="{Binding Error}" SortMemberPath="Error" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Folder}" Width="120" Binding="{Binding FolderName}" SortMemberPath="FolderName" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_NewPath}" Width="150" Binding="{Binding NewPath}" SortMemberPath="NewPath" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_SizeKB}" Width="90" Binding="{Binding SizeKB}" SortMemberPath="Size" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_SizeMB}" Width="90" Binding="{Binding SizeMB}" SortMemberPath="Size" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Created}" Width="140" Binding="{Binding CreatedDisplay}" SortMemberPath="Created" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_Modified}" Width="140" Binding="{Binding ModifiedDisplay}" SortMemberPath="Modified" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_ExifDate}" Width="140" Binding="{Binding ExifDateDisplay}" SortMemberPath="ExifDate" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_NameDigits}" Width="80" Binding="{Binding NameDigits}" SortMemberPath="NameDigits" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_PathDigits}" Width="80" Binding="{Binding PathDigits}" SortMemberPath="PathDigits" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_NameLength}" Width="80" Binding="{Binding NameLength}" SortMemberPath="NameLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_NewNameLength}" Width="100" Binding="{Binding NewNameLength}" SortMemberPath="NewNameLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_PathLength}" Width="80" Binding="{Binding PathLength}" SortMemberPath="PathLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_NewPathLength}" Width="100" Binding="{Binding NewPathLength}" SortMemberPath="NewPathLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="{DynamicResource Column_OldPath}" Width="200" Binding="{Binding OldPath}" SortMemberPath="OldPath" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <ContentControl x:Name="win32FileListHost" Visibility="Collapsed"/>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Height="28" Padding="12,0" CornerRadius="0,0,8,8"
                    MouseMove="StatusBar_MouseMove" MouseLeftButtonUp="StatusBar_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="tbStatusProgress" Grid.Column="0"
                               Text="{DynamicResource Status_Ready}" 
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <ProgressBar x:Name="pbProgress" Grid.Column="1" Height="12" Margin="8,0"
                                 VerticalAlignment="Center" Minimum="0" Maximum="100" Value="0"
                                 Visibility="Collapsed"/>

                    <TextBlock x:Name="tbStatusFiles" Grid.Column="2"
                               Text="{DynamicResource Status_FilesSummary}" 
                               VerticalAlignment="Center" FontSize="12" Margin="8,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock x:Name="tbStatusInfo" Grid.Column="3"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
