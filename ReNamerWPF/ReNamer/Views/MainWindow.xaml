<Window x:Class="ReNamer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReNamer.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" 
        Icon="/Resources/AppIcon.ico"
        Width="600" Height="720" MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="8"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:IndexConverter x:Key="IndexConverter"/>
        <!-- 状态指示器样式 -->
        <Style x:Key="StateIndicator" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="✓">
                    <Setter Property="Foreground" Value="{StaticResource SemanticSuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="×">
                    <Setter Property="Foreground" Value="{StaticResource SemanticErrorBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="→">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 现代化 ListView 项样式 -->
        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TableColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="EnterpriseDataGrid" TargetType="{x:Type DataGrid}">
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="EnterpriseDataGridColumnHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  Margin="12,0,10,0"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock x:Name="SortArrow"
                                           Grid.Column="1"
                                           Margin="6,0,12,0"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{TemplateBinding Foreground}"
                                           Visibility="Collapsed"
                                           Text="▲"/>
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       Width="12"
                                       Margin="0,-1,-1,-1"
                                       Cursor="SizeWE"
                                       Background="Transparent">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Text" Value="▲"/>
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Text" Value="▼"/>
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Ascending">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Descending">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EnterpriseDataGridRow" TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EnterpriseDataGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#FFF7D047"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- 工具栏按钮样式 -->
        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarActionButton" TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CommandBar 按钮样式 -->
        <Style x:Key="CommandBarSecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarActionButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CommandBarPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="FileToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarActionButton}">
            <Setter Property="Width" Value="108"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowRootBorder"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border x:Name="TitleBarBorder"
                    Grid.Row="0" Background="{StaticResource PrimaryBrush}" 
                    CornerRadius="8,8,0,0" Height="40"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseRightButtonUp="TitleBar_MouseRightButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 应用图标和标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                        <Path x:Name="TitleBarIcon"
                              Data="{StaticResource Icon_Rename}" Fill="White" 
                              Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleBarText"
                                   Text="{DynamicResource AppTitle}" 
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="—" Width="46" Height="40" 
                                Click="MinimizeButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0"/>
                        <Button Content="□" Width="46" Height="40" 
                                Click="MaximizeButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0"/>
                        <Button Content="✕" Width="46" Height="40" 
                                Click="CloseButton_Click"
                                Style="{StaticResource ToolbarIconButton}"
                                Foreground="White" FontSize="16" Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="Transparent" CornerRadius="0,8,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 菜单栏 -->
            <Menu Grid.Row="1" Background="{StaticResource SurfaceBrush}" Height="32">
                <MenuItem Header="{DynamicResource Menu_File}">
                    <MenuItem Header="{DynamicResource Menu_Undo}" Command="{Binding CmdUndoRename}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_AddFiles}" Command="{Binding CmdAddFiles}"/>
                    <MenuItem Header="{DynamicResource Menu_AddFolders}" Command="{Binding CmdAddFolders}"/>
                    <MenuItem Header="{DynamicResource Menu_AddPaths}" Command="{Binding CmdAddPaths}"/>
                    <MenuItem Header="{DynamicResource Menu_PasteFiles}" Command="{Binding CmdPasteFiles}"/>
                    <MenuItem Header="{DynamicResource Menu_Rename}" Command="{Binding CmdRename}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Exit}" Command="{Binding CmdExit}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Presets}">
                    <MenuItem x:Name="menuLoadPreset" Header="{DynamicResource Menu_LoadPreset}" Command="{Binding CmdLoadPreset}"/>
                    <MenuItem Header="{DynamicResource Menu_SavePresetAs}" Command="{Binding CmdSavePresetAs}"/>
                    <MenuItem Header="{DynamicResource Menu_SavePreset}" Command="{Binding CmdSavePreset}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_ManagePresets}" Command="{Binding CmdManagePresets}"/>
                    <MenuItem Header="{DynamicResource Menu_BrowsePresetsFolder}" Command="{Binding CmdBrowsePresets}"/>
                    <MenuItem Header="{DynamicResource Menu_ImportPreset}" Command="{Binding CmdImportPreset}"/>
                    <MenuItem Header="{DynamicResource Menu_RescanPresets}" Command="{Binding CmdRescanPresets}"/>
                    <MenuItem Header="{DynamicResource Menu_CreatePresetLinks}" Command="{Binding CmdCreatePresetLinks}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Settings}">
                    <MenuItem Header="{DynamicResource Menu_AllSettings}" Command="{Binding CmdSettings}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Settings_General}" Command="{Binding CmdSettingsGeneral}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Preview}" Command="{Binding CmdSettingsPreview}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Rename}" Command="{Binding CmdSettingsRename}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_MetaTags}" Command="{Binding CmdSettingsMetaTags}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Misc}" Command="{Binding CmdSettingsMisc}"/>
                    <MenuItem Header="{DynamicResource Menu_Settings_Filters}" Command="{Binding CmdSettingsFilters}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Help}">
                    <MenuItem x:Name="menuLanguage" Header="{DynamicResource Menu_Language}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_About}" Command="{Binding CmdAbout}"/>
                </MenuItem>
            </Menu>

            <!-- CommandBar（主操作栏）-->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1"
                    Padding="12,6,12,4" MinHeight="56">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Bottom" Height="2" Margin="0,4,0,0"
                            Background="{DynamicResource PrimaryBrush}" Opacity="0.25"
                            CornerRadius="1"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 添加文件 -->
                    <Button Command="{Binding CmdAddFiles}" Style="{StaticResource CommandBarSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_AddFile}" Fill="{DynamicResource PrimaryBrush}" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_AddFiles}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- 添加文件夹 -->
                    <Button Command="{Binding CmdAddFolders}" Style="{StaticResource CommandBarSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_AddFolder}" Fill="{DynamicResource SemanticWarningBrush}" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_AddFolders}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    

                    <!-- 预览 -->
                    <!-- 重命名（强调按钮）-->
                    <Button Command="{Binding CmdRename}" Style="{StaticResource CommandBarSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Rename}" Fill="{DynamicResource PrimaryBrush}" 
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Toolbar_Rename}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="3" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="200" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="150"/>
                </Grid.RowDefinitions>

                <!-- 规则面板（卡片样式）-->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="6,6,6,4" Padding="6">
                    <DockPanel>
                        <!-- 规则工具栏 -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                MinHeight="44" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding CmdAddRule}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Add}" Fill="{StaticResource SemanticSuccessBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Add}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdRemoveRule}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Remove}" Fill="{StaticResource SemanticErrorBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Remove}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdMoveRuleUp}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Up}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Up}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdMoveRuleDown}" Style="{StaticResource ToolbarActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Down}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="16" Height="16" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Down}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 规则列表 -->
                        <ListView x:Name="lvRules" SelectionMode="Extended"
                                  MouseDoubleClick="Rules_DoubleClick"
                                  SelectionChanged="Rules_SelectionChanged"
                                  PreviewMouseLeftButtonDown="Rules_PreviewMouseLeftButtonDown"
                                  MouseMove="Rules_MouseMove" Drop="Rules_Drop" DragOver="Rules_DragOver"
                                  AllowDrop="True"
                                  AlternationCount="2147483647"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  Background="{DynamicResource SurfaceBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  ItemContainerStyle="{StaticResource ModernListViewItem}">
                            <ListView.Resources>
                                <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource TableColumnHeader}"/>
                            </ListView.Resources>
                            <ListView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{DynamicResource CtxRule_Add}" Command="{Binding CmdAddRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddAbove}" Command="{Binding CmdRuleAddAbove}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_AddBelow}" Command="{Binding CmdRuleAddBelow}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Edit}" Command="{Binding CmdRuleEdit}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Duplicate}" Command="{Binding CmdRuleDuplicate}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Remove}" Command="{Binding CmdRemoveRule}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_RemoveAll}" Command="{Binding CmdRuleRemoveAll}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveUp}" Command="{Binding CmdMoveRuleUp}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MoveDown}" Command="{Binding CmdMoveRuleDown}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Menu_ExportClipboard}" Command="{Binding CmdRuleExport}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_Comment}" Command="{Binding CmdRuleComment}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxRule_SelectAll}" Command="{Binding CmdRulesSelectAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_MarkAll}" Command="{Binding CmdRulesMarkAll}"/>
                                    <MenuItem Header="{DynamicResource CtxRule_UnmarkAll}" Command="{Binding CmdRulesUnmarkAll}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled}" Click="RuleCheckBox_Click"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="#" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource IndexConverter}}" 
                                                           HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Column_Rule}" Width="100" 
                                                    DisplayMemberBinding="{Binding LocalizedRuleName}"/>
                                    <GridViewColumn Header="{DynamicResource Column_Statement}" Width="460" 
                                                    DisplayMemberBinding="{Binding LocalizedDisplayDescription}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>

                <!-- 分隔器 -->
                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" 
                              Background="Transparent" VerticalAlignment="Center"/>

                <!-- 文件列表面板（卡片样式）-->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="6,4,6,6" Padding="6">
                    <DockPanel>
                        <!-- 文件工具栏 -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                MinHeight="44" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding CmdFilters}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Filter}" Fill="{StaticResource InfoBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Filters}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdOptions}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource TextSecondaryBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Options}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdAnalyze}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Analyze}" Fill="{StaticResource PrimaryBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Analyze}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CmdValidate}" Style="{StaticResource FileToolbarButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon_Check}" Fill="{StaticResource SemanticSuccessBrush}" 
                                              Width="14" Height="14" Stretch="Uniform"/>
                                        <TextBlock Text="{DynamicResource Toolbar_Validate}" Margin="6,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 文件列表 -->
                        <DataGrid x:Name="lvFiles" SelectionMode="Extended" SelectionUnit="FullRow" AllowDrop="True"
                                  SelectionChanged="Files_SelectionChanged"
                                  PreviewMouseLeftButtonDown="Files_PreviewMouseLeftButtonDown"
                                  MouseMove="Files_MouseMove" Drop="Files_Drop" DragOver="Files_DragOver"
                                  Sorting="FilesColumnHeader_Click"
                                  Style="{StaticResource EnterpriseDataGrid}"
                                  RowStyle="{StaticResource EnterpriseDataGridRow}"
                                  CellStyle="{StaticResource EnterpriseDataGridCell}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                            <DataGrid.Resources>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextWrapping" Value="NoWrap"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                <Style x:Key="CenteredCellText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
                                <Style x:Key="ChangedNewNameText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredCellText}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasChanged}" Value="True"/>
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                                <Style x:Key="RightAlignedCellText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredCellText}">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                                <Style x:Key="CenteredEditingCellTextBox" TargetType="{x:Type TextBox}">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                                <Style x:Key="CenteredFileCheckBox" TargetType="{x:Type CheckBox}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource EnterpriseDataGridColumnHeader}">
                                    <EventSetter Event="MouseRightButtonUp" Handler="FilesColumnHeader_RightClick"/>
                                    <EventSetter Event="MouseDoubleClick" Handler="FilesColumnHeader_DoubleClick"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding CmdRemoveSelectedFiles}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{DynamicResource CtxFile_EditNewName}" Command="{Binding CmdEditNewName}"/>
                                    <MenuItem Header="{DynamicResource Menu_AnalyzeName}" Command="{Binding CmdAnalyze}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxFile_Shell}">
                                        <MenuItem Header="{DynamicResource CtxFile_OpenFile}" Command="{Binding CmdOpenFile}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_OpenFolder}" Command="{Binding CmdOpenFolder}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_OpenWithNotepad}" Command="{Binding CmdOpenWithNotepad}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_Properties}" Command="{Binding CmdFileProperties}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_CutToClipboard}" Command="{Binding CmdCutFiles}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_CopyToClipboard}" Command="{Binding CmdCopyFiles}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_DeleteRecycle}" Command="{Binding CmdDeleteRecycle}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Mark}">
                                        <MenuItem Header="{DynamicResource CtxFile_MarkItem}" Command="{Binding CmdMarkSelected}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_UnmarkItem}" Command="{Binding CmdUnmarkSelected}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_InvertMarking}" Command="{Binding CmdInvertMarking}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkChangedIncCase}" Command="{Binding CmdMarkChangedIncCase}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkChangedExcCase}" Command="{Binding CmdMarkChangedExcCase}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkByMask}" Command="{Binding CmdMarkByMask}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MarkOnlySelected}" Command="{Binding CmdMarkOnlySelected}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Clear}">
                                        <MenuItem Header="{DynamicResource CtxFile_ClearAll}" Command="{Binding CmdClearAll}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearRenamed}" Command="{Binding CmdClearRenamed}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearFailed}" Command="{Binding CmdClearFailed}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearValid}" Command="{Binding CmdClearValid}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearInvalid}" Command="{Binding CmdClearInvalid}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearNotChanged}" Command="{Binding CmdClearNotChanged}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearMarked}" Command="{Binding CmdClearMarked}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_ClearNotMarked}" Command="{Binding CmdClearNotMarked}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Select}">
                                        <MenuItem Header="{DynamicResource CtxFile_SelectAll}" Command="{Binding CmdFilesSelectAll}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_InvertSelection}" Command="{Binding CmdInvertSelection}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource CtxFile_SelectByNameLength}" Command="{Binding CmdSelectByNameLength}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_SelectByExtension}" Command="{Binding CmdSelectByExtension}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_SelectByMask}" Command="{Binding CmdSelectByMask}"/>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource CtxFile_Move}">
                                        <MenuItem Header="{DynamicResource CtxFile_MoveUp}" Command="{Binding CmdMoveFileUp}"/>
                                        <MenuItem Header="{DynamicResource CtxFile_MoveDown}" Command="{Binding CmdMoveFileDown}"/>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CtxFile_RemoveSelected}" InputGestureText="Del" Command="{Binding CmdRemoveSelectedFiles}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="44" SortMemberPath="IsMarked">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredFileCheckBox}"
                                                      Click="FileHeaderCheckBox_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource EnterpriseDataGridCell}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredFileCheckBox}"
                                                      IsChecked="{Binding IsMarked}"
                                                      Click="FileCheckBox_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="{DynamicResource Column_State}" Width="50" SortMemberPath="State">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding State}" Style="{StaticResource StateIndicator}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource Column_Name}" Width="220" Binding="{Binding OriginalName}" SortMemberPath="OriginalName" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_NewName}" Width="220" Binding="{Binding NewName}" SortMemberPath="NewName" ElementStyle="{StaticResource ChangedNewNameText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Path}" Width="200" Binding="{Binding FolderPath}" SortMemberPath="FolderPath" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Extension}" Width="70" Binding="{Binding Extension}" SortMemberPath="Extension" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Size}" Width="90" Binding="{Binding SizeDisplay}" SortMemberPath="SizeDisplay" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Error}" Width="150" Binding="{Binding Error}" SortMemberPath="Error" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Folder}" Width="120" Binding="{Binding FolderName}" SortMemberPath="FolderName" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_NewPath}" Width="200" Binding="{Binding NewPath}" SortMemberPath="NewPath" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_SizeKB}" Width="90" Binding="{Binding SizeKB}" SortMemberPath="SizeKB" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_SizeMB}" Width="90" Binding="{Binding SizeMB}" SortMemberPath="SizeMB" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Created}" Width="140" Binding="{Binding CreatedDisplay}" SortMemberPath="CreatedDisplay" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_Modified}" Width="140" Binding="{Binding ModifiedDisplay}" SortMemberPath="ModifiedDisplay" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_ExifDate}" Width="140" Binding="{Binding ExifDateDisplay}" SortMemberPath="ExifDateDisplay" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_NameDigits}" Width="80" Binding="{Binding NameDigits}" SortMemberPath="NameDigits" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_PathDigits}" Width="80" Binding="{Binding PathDigits}" SortMemberPath="PathDigits" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_NameLength}" Width="80" Binding="{Binding NameLength}" SortMemberPath="NameLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_NewNameLength}" Width="100" Binding="{Binding NewNameLength}" SortMemberPath="NewNameLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_PathLength}" Width="80" Binding="{Binding PathLength}" SortMemberPath="PathLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_NewPathLength}" Width="100" Binding="{Binding NewPathLength}" SortMemberPath="NewPathLength" ElementStyle="{StaticResource RightAlignedCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="{DynamicResource Column_OldPath}" Width="200" Binding="{Binding OldPath}" SortMemberPath="OldPath" ElementStyle="{StaticResource CenteredCellText}" EditingElementStyle="{StaticResource CenteredEditingCellTextBox}" Visibility="Collapsed"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Height="32" Padding="16,0" CornerRadius="0,0,8,8"
                    MouseMove="StatusBar_MouseMove" MouseLeftButtonUp="StatusBar_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="tbStatusProgress" Grid.Column="0"
                               Text="{DynamicResource Status_Ready}" 
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <ProgressBar x:Name="pbProgress" Grid.Column="1" Height="14" Margin="8,0"
                                 VerticalAlignment="Center" Minimum="0" Maximum="100" Value="0"
                                 Visibility="Collapsed"/>

                    <TextBlock x:Name="tbStatusFiles" Grid.Column="2"
                               Text="{DynamicResource Status_FilesSummary}" 
                               VerticalAlignment="Center" FontSize="13" Margin="8,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock x:Name="tbStatusInfo" Grid.Column="3"
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
