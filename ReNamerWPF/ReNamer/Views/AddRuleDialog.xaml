<Window x:Class="ReNamer.Views.AddRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dialog_AddRule}" 
        Width="780" Height="520"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        MinWidth="780" MinHeight="520"
        AllowDrop="True"
        Drop="AddRuleDialog_Drop"
        DragOver="AddRuleDialog_DragOver"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 上半部分：左右分栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：规则类型列表 -->
            <Border Grid.Column="0" Style="{StaticResource EnterpriseDialogCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource Icon_Add}" Width="14" Height="14" Fill="{DynamicResource InfoBrush}" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Dialog_RuleTypes}"
                                   Style="{StaticResource DialogSectionHeaderText}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>

                    <ListBox x:Name="lbRules" Grid.Row="2"
                             SelectionMode="Single"
                             SelectionChanged="Rules_SelectionChanged"
                             MouseDoubleClick="ListBox_DoubleClick"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="2">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Dialog_RuleDescription}" Click="RuleDescription_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <Path Data="{Binding Icon}" Fill="{DynamicResource TextBrush}"
                                          Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- 右侧：配置面板 -->
            <Border Grid.Column="2" Style="{StaticResource EnterpriseDialogCardStyle}" MinHeight="380">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{Binding ElementName=lbRules, Path=SelectedItem.Icon}"
                              Width="16"
                              Height="16"
                              Fill="{DynamicResource TextBrush}"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ElementName=lbRules, Path=SelectedItem.Name}"
                                   Style="{StaticResource DialogSectionHeaderText}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl x:Name="configPanel" Margin="0"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- 底部按钮 -->
        <Border Grid.Row="1" Style="{StaticResource EnterpriseDialogCardStyle}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnAddRule"
                            Content="{DynamicResource Dialog_AddRule}"
                            Margin="0,0,12,0"
                            Click="AddRule_Click"
                            IsDefault="True"
                            Style="{StaticResource EnterpriseDialogPrimaryActionButtonStyle}"/>
                    <Button Content="{DynamicResource Dialog_Close}"
                            Click="Close_Click"
                            IsCancel="True"
                            Style="{StaticResource EnterpriseDialogSecondaryActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
