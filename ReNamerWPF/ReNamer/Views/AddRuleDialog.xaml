<Window x:Class="ReNamer.Views.AddRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dialog_AddRule}" 
        Width="780" Height="520"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        MinWidth="780" MinHeight="520"
        AllowDrop="True"
        Drop="AddRuleDialog_Drop"
        DragOver="AddRuleDialog_DragOver"
        Background="{DynamicResource BackgroundBrush}">
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 上半部分：左右分栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：规则类型列表 -->
            <ListBox x:Name="lbRules" Grid.Column="0" 
                     Margin="0,0,8,0"
                     SelectionMode="Single"
                     SelectionChanged="Rules_SelectionChanged"
                     MouseDoubleClick="ListBox_DoubleClick"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Background="{DynamicResource SurfaceBrush}"
                     Padding="4">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource Dialog_RuleDescription}" Click="RuleDescription_Click"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <Path Data="{Binding Icon}" Fill="{DynamicResource TextBrush}"
                                  Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <!-- 右侧：配置面板 -->
            <GroupBox Grid.Column="1" 
                      x:Name="grpConfig"
                      Header="{DynamicResource Dialog_Configuration}"
                      MinHeight="380">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl x:Name="configPanel" Margin="6"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>
        
        <!-- 底部按钮 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" 
                    x:Name="btnAddRule"
                    Content="{DynamicResource Menu_AddRule}" 
                    Height="36"
                    Margin="0,0,10,0"
                    Click="AddRule_Click"
                    IsDefault="True"
                    MinWidth="120"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Grid.Column="1" 
                    Content="{DynamicResource Dialog_Close}" 
                    Height="36"
                    Click="Close_Click"
                    IsCancel="True"
                    MinWidth="120"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
