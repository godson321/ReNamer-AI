<Window x:Class="ReNamer.Views.FiltersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dialog_FilterSettings}" Width="1020" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource EnterpriseDialogCardStyle}"
                Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{DynamicResource Icon_Filters}" Width="16" Height="16" Fill="{DynamicResource PrimaryBrush}" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Dialog_FilterSettings}" Style="{StaticResource DialogSectionHeaderText}" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource Filter_Tips}" Style="{StaticResource DialogHintText}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource EnterpriseDialogCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource Icon_Filter}" Width="14" Height="14" Fill="{DynamicResource InfoBrush}" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Dialog_Filters}"
                                   Style="{StaticResource DialogSectionHeaderText}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="118"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource Filters_Pattern}"
                                   Style="{StaticResource DialogLabelText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="txtNamePattern" Style="{StaticResource EnterpriseDialogInputTextBoxStyle}" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton x:Name="rbNameInclude" Content="{DynamicResource Filters_Include}" GroupName="NameMode" Margin="0,0,12,0"/>
                                <RadioButton x:Name="rbNameExclude" Content="{DynamicResource Filters_Exclude}" GroupName="NameMode" Margin="0,0,12,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{DynamicResource Filters_Extensions}"
                                   Style="{StaticResource DialogLabelText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtExtensions" Style="{StaticResource EnterpriseDialogInputTextBoxStyle}" MinWidth="260" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{DynamicResource Filters_SizeFilter}"
                                   Style="{StaticResource DialogLabelText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Filters_Min}" Style="{StaticResource DialogLabelText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1" x:Name="txtMinSize" Style="{StaticResource EnterpriseDialogInputTextBoxStyle}" Margin="0,0,6,0"/>
                            <ComboBox Grid.Column="2" x:Name="cmbMinUnit" Style="{StaticResource EnterpriseDialogInputComboBoxStyle}" MinWidth="84" Margin="0,0,12,0">
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_B}" />
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_KB}" />
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_MB}" />
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_GB}" />
                            </ComboBox>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Filters_Max}" Style="{StaticResource DialogLabelText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="4" x:Name="txtMaxSize" Style="{StaticResource EnterpriseDialogInputTextBoxStyle}" Margin="0,0,6,0"/>
                            <ComboBox Grid.Column="5" x:Name="cmbMaxUnit" Style="{StaticResource EnterpriseDialogInputComboBoxStyle}" MinWidth="84" Margin="0,0,4,0">
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_B}" />
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_KB}" />
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_MB}" />
                                <ComboBoxItem Content="{DynamicResource Filters_Unit_GB}" />
                            </ComboBox>
                        </Grid>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="{DynamicResource Filters_AttrFilter}"
                                   Style="{StaticResource DialogLabelText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <CheckBox x:Name="chkAttrReadOnly" Content="{DynamicResource Filters_ReadOnly}" Margin="0,0,14,0"/>
                            <CheckBox x:Name="chkAttrHidden" Content="{DynamicResource Filters_Hidden}" Margin="0,0,14,0"/>
                            <CheckBox x:Name="chkAttrSystem" Content="{DynamicResource Filters_System}" Margin="0,0,14,0"/>
                            <CheckBox x:Name="chkNameCaseSensitive" Content="{DynamicResource Filters_CaseSensitive}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{DynamicResource Filters_EnableAttrFilter}"
                                   Style="{StaticResource DialogLabelText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <CheckBox Grid.Row="4" Grid.Column="1"
                                  x:Name="chkFiltersApplied"
                                  Content="{DynamicResource Filters_EnableListFilter}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,4,0,0">
                        <TextBlock Text="{DynamicResource Filters_WildcardsHint}" Style="{StaticResource DialogHintText}"/>
                        <TextBlock Text="{DynamicResource Filters_ExtensionsHint}" Style="{StaticResource DialogHintText}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource EnterpriseDialogCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="118"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource Icon_Settings}" Width="14" Height="14" Fill="{DynamicResource InfoBrush}" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Filter_FolderDefaults}"
                                   Style="{StaticResource DialogSectionHeaderText}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>

                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="chkIncludeAllFiles" Content="{DynamicResource Filter_IncludeAllFiles}" Margin="0,0,14,8"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkIncludeFolderName" Content="{DynamicResource Filter_IncludeFolderNames}" Margin="0,0,0,8"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="chkIncludeSubFolders" Content="{DynamicResource Filter_IncludeSubfolders}" Margin="0,0,14,8"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="chkIncludeHiddenFiles" Content="{DynamicResource Filter_IncludeHiddenFiles}" Margin="0,0,0,8"/>
                        <CheckBox Grid.Row="2" Grid.Column="0" x:Name="chkIncludeSystemFiles" Content="{DynamicResource Filter_IncludeSystemFiles}" Margin="0,0,14,0"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkIgnoreRootFolder" Content="{DynamicResource Filter_IgnoreRootFolder}" Margin="0,0,0,0"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Filter_IncludeLabel}" Style="{StaticResource DialogLabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtIncludePattern" Style="{StaticResource EnterpriseDialogInputTextBoxStyle}" MinWidth="220" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Filter_ExcludeLabel}" Style="{StaticResource DialogLabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtExcludePattern" Style="{StaticResource EnterpriseDialogInputTextBoxStyle}" MinWidth="220" Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
                        <CheckBox x:Name="chkPatternFileNameOnly" Content="{DynamicResource Filter_FileNameOnly}" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Filter_Tips}" Style="{StaticResource DialogHintText}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource EnterpriseDialogCardStyle}"
                Padding="12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="chkSaveAsDefault" Content="{DynamicResource Filter_SaveAsDefault}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{DynamicResource Dialog_Save}" Margin="0,0,12,0" Click="Save_Click" IsDefault="True"
                            Style="{StaticResource EnterpriseDialogPrimaryActionButtonStyle}"/>
                    <Button Content="{DynamicResource Dialog_Cancel}" Click="Cancel_Click" IsCancel="True"
                            Style="{StaticResource EnterpriseDialogSecondaryActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
