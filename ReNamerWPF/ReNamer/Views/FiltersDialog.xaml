<Window x:Class="ReNamer.Views.FiltersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dialog_Filters}" Width="460" Height="440"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- File Name Pattern -->
            <GroupBox Header="{DynamicResource Filters_NameFilter}" Margin="0,0,0,10">
                <StackPanel Margin="8">
                    <CheckBox x:Name="chkEnableNameFilter" Content="{DynamicResource Filters_EnableNameFilter}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource Filters_Pattern}" Style="{StaticResource DialogLabelText}" Width="60"/>
                        <TextBox x:Name="txtNamePattern" Width="200" ToolTip="{DynamicResource Filters_WildcardsHint}"/>
                        <ComboBox x:Name="cmbNameFilterMode" Width="100" Margin="8,0,0,0">
                            <ComboBoxItem Content="{DynamicResource Filters_Include}" IsSelected="True"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Exclude}"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="chkNameCaseSensitive" Content="{DynamicResource Config_CaseSensitive}" Margin="60,4,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Extension Filter -->
            <GroupBox Header="{DynamicResource Filters_ExtFilter}" Margin="0,0,0,10">
                <StackPanel Margin="8">
                    <CheckBox x:Name="chkEnableExtFilter" Content="{DynamicResource Filters_EnableExtFilter}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Filters_Extensions}" Style="{StaticResource DialogLabelText}" Width="72"/>
                        <TextBox x:Name="txtExtensions" Width="260" ToolTip="{DynamicResource Filters_ExtensionsHint}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Size Filter -->
            <GroupBox Header="{DynamicResource Filters_SizeFilter}" Margin="0,0,0,10">
                <StackPanel Margin="8">
                    <CheckBox x:Name="chkEnableSizeFilter" Content="{DynamicResource Filters_EnableSizeFilter}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Filters_Min}" Style="{StaticResource DialogLabelText}" Width="40"/>
                        <TextBox x:Name="txtMinSize" Width="80" Text="0"/>
                        <ComboBox x:Name="cmbMinSizeUnit" Width="60" Margin="4,0,16,0">
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_B}"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_KB}" IsSelected="True"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_MB}"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_GB}"/>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource Filters_Max}" Style="{StaticResource DialogLabelText}" Width="40"/>
                        <TextBox x:Name="txtMaxSize" Width="80" Text="0"/>
                        <ComboBox x:Name="cmbMaxSizeUnit" Width="60" Margin="4,0,0,0">
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_B}"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_KB}"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_MB}" IsSelected="True"/>
                            <ComboBoxItem Content="{DynamicResource Filters_Unit_GB}"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Attributes Filter -->
            <GroupBox Header="{DynamicResource Filters_AttrFilter}" Margin="0,0,0,10">
                <StackPanel Margin="8" Orientation="Horizontal">
                    <CheckBox x:Name="chkEnableAttrFilter" Content="{DynamicResource Filters_EnableAttrFilter}" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkAttrReadOnly" Content="{DynamicResource Filters_ReadOnly}" Margin="0,0,12,0"/>
                    <CheckBox x:Name="chkAttrHidden" Content="{DynamicResource Filters_Hidden}" Margin="0,0,12,0"/>
                    <CheckBox x:Name="chkAttrSystem" Content="{DynamicResource Filters_System}" Margin="0,0,12,0"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource Dialog_Apply}" Width="90" Margin="0,0,8,0" Click="Apply_Click" IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="{DynamicResource Dialog_ClearAll}" Width="90" Margin="0,0,8,0" Click="ClearAll_Click"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <Button Content="{DynamicResource Dialog_Close}" Width="90" Click="Close_Click" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
