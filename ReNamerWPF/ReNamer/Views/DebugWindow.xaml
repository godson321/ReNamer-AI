<Window x:Class="ReNamer.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:ReNamer.Helpers"
        mc:Ignorable="d"
        Title="Debug Window - Clipboard Test" Height="550" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="普通 TextBox" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="在这些文本框中测试 Ctrl+C / Ctrl+V / Ctrl+X：" Margin="0,0,0,5"/>
                <TextBox x:Name="txtA1" Margin="0,0,0,5" Text="普通文本框1"/>
                <TextBox x:Name="txtA2" Margin="0,0,0,5" 
                         Style="{DynamicResource EnterpriseDialogInputTextBoxStyle}"
                         helpers:PlaceholderBehavior.Placeholder="普通文本框2 - 带样式"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="分组内 TextBox" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="在这些文本框中测试 Ctrl+C / Ctrl+V / Ctrl+X：" Margin="0,0,0,5"/>
                <TextBox x:Name="txtB1" Margin="0,0,0,5" Text="分组文本框1"/>
                <TextBox x:Name="txtB2" Margin="0,0,0,5" 
                         Style="{DynamicResource EnterpriseDialogInputTextBoxStyle}"
                         helpers:PlaceholderBehavior.Placeholder="分组文本框2 - 带样式"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="事件日志">
            <TextBox x:Name="txtLog" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" 
                     IsReadOnly="True" FontFamily="Consolas" FontSize="11"/>
        </GroupBox>

        <Button Grid.Row="3" Content="清除日志" Click="Button_Click" 
                HorizontalAlignment="Right" Margin="0,5,0,0" Padding="12,4"/>
    </Grid>
</Window>
