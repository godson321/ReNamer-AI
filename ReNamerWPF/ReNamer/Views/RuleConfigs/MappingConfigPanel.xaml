<UserControl x:Class="ReNamer.Views.RuleConfigs.MappingConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280"
             Background="{DynamicResource CardBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnTable" Grid.Column="0" Content="{DynamicResource RuleCfg_Mapping_Table}" MinWidth="88" Margin="3"
                    Style="{DynamicResource SecondaryButtonStyle}" Click="BtnTable_Click"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <CheckBox x:Name="chkAllowReuse" Content="{DynamicResource RuleCfg_Mapping_AllowReuse}" Margin="0,2,16,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkPartialMatch" Content="{DynamicResource RuleCfg_Mapping_PartialMatch}" Margin="0,2,16,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkInverse" Content="{DynamicResource RuleCfg_Mapping_Inverse}" Margin="0,2,0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <CheckBox x:Name="chkCaseSensitive" Content="{DynamicResource Config_CaseSensitive}" Margin="0,2,16,2" VerticalContentAlignment="Center"/>
            <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" Margin="0,2,0,2" VerticalContentAlignment="Center"/>
        </StackPanel>
        <!-- DataGrid for mappings -->
        <DataGrid x:Name="dgMappings" Grid.Row="4" AutoGenerateColumns="False" CanUserAddRows="True"
                  CanUserDeleteRows="True" HeadersVisibility="Column" GridLinesVisibility="All"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource RuleCfg_Mapping_Match}" Binding="{Binding Match}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource RuleCfg_Mapping_NewName}" Binding="{Binding NewName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
