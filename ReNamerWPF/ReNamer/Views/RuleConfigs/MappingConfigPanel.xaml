<UserControl x:Class="ReNamer.Views.RuleConfigs.MappingConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="{DynamicResource RuleCfg_Mapping_TableActions}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.Resources>
                    <Style x:Key="MappingActionButtonStyle" TargetType="Button" BasedOn="{DynamicResource EnterpriseDialogSecondaryActionButtonStyle}">
                        <Setter Property="MinWidth" Value="0"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource MappingActionButtonStyle}"
                        Click="BtnLoadFromFile_Click"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{StaticResource Icon_Files}" Fill="{DynamicResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        <TextBlock Text="{DynamicResource RuleCfg_Mapping_LoadFromFile}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource MappingActionButtonStyle}"
                        Click="BtnLoadFromClipboard_Click"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{StaticResource Icon_Duplicate}" Fill="{DynamicResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        <TextBlock Text="{DynamicResource RuleCfg_Mapping_LoadFromClipboard}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource MappingActionButtonStyle}"
                        Click="BtnSaveToFile_Click"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{StaticResource Icon_Export}" Fill="{DynamicResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        <TextBlock Text="{DynamicResource RuleCfg_Mapping_SaveToFile}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="0" Grid.Column="3"
                        Style="{StaticResource MappingActionButtonStyle}"
                        Click="BtnClearMappings_Click"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Margin="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{StaticResource Icon_RemoveItem}" Fill="{DynamicResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        <TextBlock Text="{DynamicResource RuleCfg_Mapping_Clear}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="{DynamicResource RuleCfg_Section_Options}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource RuleCfg_Mapping_MatchOptions}" Style="{DynamicResource SectionHeaderStyle}" Margin="0,0,0,2"/>
                    <CheckBox x:Name="chkPartialMatch" Content="{DynamicResource RuleCfg_Mapping_PartialMatch}" Margin="0,1" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkCaseSensitive" Content="{DynamicResource Config_CaseSensitive}" Margin="0,1" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkInverse" Content="{DynamicResource RuleCfg_Mapping_Inverse}" Margin="0,1" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource RuleCfg_Mapping_ApplyOptions}" Style="{DynamicResource SectionHeaderStyle}" Margin="0,0,0,2"/>
                    <CheckBox x:Name="chkAllowReuse" Content="{DynamicResource RuleCfg_Mapping_AllowReuse}" Margin="0,1" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" Margin="0,1" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="{DynamicResource RuleCfg_Mapping_DataGroup}">
            <Grid Margin="6,4">
                <DataGrid x:Name="dgMappings"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource RuleCfg_Mapping_Match}" Binding="{Binding Match}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource RuleCfg_Mapping_NewName}" Binding="{Binding NewName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border IsHitTestVisible="False" Background="{DynamicResource CardBrush}" Opacity="0.85" Margin="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=dgMappings, Path=HasItems}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{DynamicResource RuleCfg_Mapping_EmptyHint}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Style="{DynamicResource DialogHintText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="16"/>
                </Border>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
