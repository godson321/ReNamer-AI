<UserControl x:Class="ReNamer.Views.RuleConfigs.DeleteConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280"
             Background="{DynamicResource CardBrush}">
    <StackPanel Margin="16,12">
        <!-- From / Until groups -->
        <Grid Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- From group -->
            <GroupBox Header="{DynamicResource Delete_From}" HorizontalAlignment="Stretch">
                <StackPanel Margin="8,6">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>

                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="rbFromPosition" Content="{DynamicResource Delete_Position}" GroupName="From" IsChecked="True" VerticalContentAlignment="Center"/>
                        <controls:NumericUpDown x:Name="nudFromPosition" Grid.Column="1" MinWidth="100" MinValue="1" MaxValue="999999" Value="1"
                                                HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="rbFromDelimiter" Content="{DynamicResource Delete_Delimiter}" GroupName="From" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="txtFromDelimiter" Grid.Column="1" MinWidth="100" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                 helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_DeleteFromDelimiter}"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
            <!-- Until group -->
            <GroupBox Grid.Column="2" Header="{DynamicResource Delete_Until}" HorizontalAlignment="Stretch">
                <StackPanel Margin="8,6">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="rbUntilCount" Content="{DynamicResource Delete_Count}" GroupName="Until" IsChecked="True" VerticalContentAlignment="Center"/>
                        <controls:NumericUpDown x:Name="nudUntilCount" Grid.Column="1"  MinWidth="100"  MinValue="1" MaxValue="999999" Value="1"
                                                HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="rbUntilDelimiter" Content="{DynamicResource Delete_Delimiter}" GroupName="Until" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="txtUntilDelimiter" Grid.Column="1" MinWidth="100" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                 helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_DeleteUntilDelimiter}"/>
                    </Grid>
                    <RadioButton x:Name="rbUntilEnd" Content="{DynamicResource Delete_TillEnd}" GroupName="Until" Margin="0,4" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>
        </Grid>
        <!-- Options row -->
        <Grid Margin="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <CheckBox x:Name="chkDeleteCurrentName" Content="{DynamicResource Delete_CurrentName}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Delete_SkipExtension}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <CheckBox x:Name="chkRightToLeft" Content="{DynamicResource Delete_RightToLeft}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkLeaveDelimiter" Content="{DynamicResource Delete_LeaveDelimiter}" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
