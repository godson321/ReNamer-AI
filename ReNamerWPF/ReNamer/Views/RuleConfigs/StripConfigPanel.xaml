<UserControl x:Class="ReNamer.Views.RuleConfigs.StripConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280"
             Background="{DynamicResource CardBrush}">
    <StackPanel>
        <!-- Character types -->
        <GroupBox Header="{DynamicResource RuleCfg_Strip_Section_Characters}" Margin="0,0,0,8">
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox x:Name="chkEnglish" Content="{DynamicResource RuleCfg_Strip_English}" Grid.Row="0" VerticalContentAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="abcdefghijklmnopqrstuvwxyz" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="8,4,0,4"/>
                
                <CheckBox x:Name="chkDigits" Content="{DynamicResource RuleCfg_Strip_Digits}" Grid.Row="1" VerticalContentAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="1234567890" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="8,4,0,4"/>
                
                <CheckBox x:Name="chkSymbols" Content="{DynamicResource RuleCfg_Strip_Symbols}" Grid.Row="2" VerticalContentAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="!#$%&amp;*+,-./:;=?@\^_`|~" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="8,4,0,4"/>
                
                <CheckBox x:Name="chkBrackets" Content="{DynamicResource RuleCfg_Strip_Brackets}" Grid.Row="3" VerticalContentAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="()[]{}" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="8,4,0,4"/>
                
                <CheckBox x:Name="chkUserDefined" Content="{DynamicResource RuleCfg_Strip_UserDefined}" Grid.Row="4" VerticalContentAlignment="Center" Margin="0,4"/>
                <TextBox x:Name="txtUserDefined" Grid.Row="4" Grid.Column="1" Margin="8,4,0,4"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_StripUserDefined}"/>
                
                <CheckBox x:Name="chkUnicodeRange" Content="{DynamicResource RuleCfg_Strip_UnicodeRange}" Grid.Row="5" VerticalContentAlignment="Center" Margin="0,4"/>
                <TextBox x:Name="txtUnicodeRange" Grid.Row="5" Grid.Column="1" Margin="8,4,0,4"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_StripUnicodeRange}"/>
            </Grid>
        </GroupBox>
        
        <!-- Where + Options -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <GroupBox Header="{DynamicResource RuleCfg_Strip_Section_Where}">
                <StackPanel Margin="8,6">
                    <RadioButton x:Name="rbEverywhere" Content="{DynamicResource RuleCfg_Strip_Everywhere}" GroupName="Where" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbLeading" Content="{DynamicResource RuleCfg_Strip_Leading}" GroupName="Where" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbTrailing" Content="{DynamicResource RuleCfg_Strip_Trailing}" GroupName="Where" Margin="0,2" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>
            
            <GroupBox Grid.Column="2" Header="{DynamicResource RuleCfg_Section_Options}">
                <StackPanel Margin="8,6">
                    <CheckBox x:Name="chkAllExcept" Content="{DynamicResource RuleCfg_Strip_AllExcept}" Margin="0,2" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkCaseSensitive" Content="{DynamicResource Config_CaseSensitive}" Margin="0,2" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </StackPanel>
</UserControl>
