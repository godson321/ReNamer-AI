<UserControl x:Class="ReNamer.Views.RuleConfigs.StripConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="440" MinHeight="280">
    <Grid Margin="16,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Character types -->
        <CheckBox x:Name="chkEnglish" Content="English:" Grid.Row="0" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="abcdefghijklmnopqrstuvwxyz" IsReadOnly="True" Background="#F0F0F0" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkDigits" Content="Digits:" Grid.Row="1" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="1234567890" IsReadOnly="True" Background="#F0F0F0" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkSymbols" Content="Symbols:" Grid.Row="2" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="!#$%&amp;*+,-./:;=?@\^_`|~" IsReadOnly="True" Background="#F0F0F0" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkBrackets" Content="Brackets:" Grid.Row="3" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="()[]{}" IsReadOnly="True" Background="#F0F0F0" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkUserDefined" Content="User defined:" Grid.Row="4" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox x:Name="txtUserDefined" Grid.Row="4" Grid.Column="1" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkUnicodeRange" Content="Unicode range:" Grid.Row="5" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox x:Name="txtUnicodeRange" Grid.Row="5" Grid.Column="1" Text="10000-10FFFF" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <!-- Where + Options -->
        <Grid Grid.Row="6" Grid.ColumnSpan="2" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <StackPanel>
                    <RadioButton x:Name="rbEverywhere" Content="Everywhere" GroupName="Where" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbLeading" Content="Leading" GroupName="Where" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbTrailing" Content="Trailing" GroupName="Where" Margin="0,2" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="24,0,0,0">
                <CheckBox x:Name="chkAllExcept" Content="Strip all characters except selected" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkCaseSensitive" Content="Case sensitive" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension" Content="Skip extension" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
