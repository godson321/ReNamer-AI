<UserControl x:Class="ReNamer.Views.RuleConfigs.StripConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280">
    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Character types -->
        <CheckBox x:Name="chkEnglish" Content="{DynamicResource RuleCfg_Strip_English}" Grid.Row="0" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="abcdefghijklmnopqrstuvwxyz" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkDigits" Content="{DynamicResource RuleCfg_Strip_Digits}" Grid.Row="1" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="1234567890" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkSymbols" Content="{DynamicResource RuleCfg_Strip_Symbols}" Grid.Row="2" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="!#$%&amp;*+,-./:;=?@\^_`|~" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkBrackets" Content="{DynamicResource RuleCfg_Strip_Brackets}" Grid.Row="3" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="()[]{}" IsReadOnly="True" Background="{DynamicResource ReadOnlyTextBoxBrush}" Margin="4,2" HorizontalAlignment="Stretch"/>
        
        <CheckBox x:Name="chkUserDefined" Content="{DynamicResource RuleCfg_Strip_UserDefined}" Grid.Row="4" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox x:Name="txtUserDefined" Grid.Row="4" Grid.Column="1" Margin="4,2" HorizontalAlignment="Stretch"
                 helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_StripUserDefined}"/>
        
        <CheckBox x:Name="chkUnicodeRange" Content="{DynamicResource RuleCfg_Strip_UnicodeRange}" Grid.Row="5" VerticalContentAlignment="Center" Margin="0,2" HorizontalAlignment="Left"/>
        <TextBox x:Name="txtUnicodeRange" Grid.Row="5" Grid.Column="1" Margin="4,2" HorizontalAlignment="Stretch"
                 helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_StripUnicodeRange}"/>
        
        <!-- Where + Options -->
        <Grid Grid.Row="6" Grid.ColumnSpan="2" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <StackPanel>
                    <RadioButton x:Name="rbEverywhere" Content="{DynamicResource RuleCfg_Strip_Everywhere}" GroupName="Where" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbLeading" Content="{DynamicResource RuleCfg_Strip_Leading}" GroupName="Where" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbTrailing" Content="{DynamicResource RuleCfg_Strip_Trailing}" GroupName="Where" Margin="0,2" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="24,0,0,0">
                <CheckBox x:Name="chkAllExcept" Content="{DynamicResource RuleCfg_Strip_AllExcept}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkCaseSensitive" Content="{DynamicResource Config_CaseSensitive}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
