<UserControl x:Class="ReNamer.Views.RuleConfigs.RandomizeConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280">
    <StackPanel Margin="16,12">
        <!-- Length -->
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource RuleCfg_Randomize_Length}" VerticalAlignment="Center" Style="{DynamicResource FormLabelStyle}" Width="80" TextAlignment="Right"/>
            <controls:NumericUpDown x:Name="nudLength" Width="60" MinValue="1" MaxValue="260" Value="8"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </DockPanel>
        <!-- Unique -->
        <CheckBox x:Name="chkUnique" Content="{DynamicResource RuleCfg_Randomize_Unique}" IsChecked="True" Margin="0,0,0,8" VerticalContentAlignment="Center"/>
        <!-- Character set + Insert where -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Header="{DynamicResource RuleCfg_Randomize_CharactersToUse}" HorizontalAlignment="Stretch">
                <StackPanel Margin="8,4">
                    <CheckBox x:Name="chkDigits" Content="{DynamicResource RuleCfg_Randomize_Digits}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkLetters" Content="{DynamicResource RuleCfg_Randomize_Letters}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkUserDefined" Content="{DynamicResource RuleCfg_Randomize_UserDefined}" Margin="0,2" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtUserDefined" Margin="0,4,0,0" VerticalAlignment="Center"
                             helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_RandomizeUserDefined}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="{DynamicResource RuleCfg_Randomize_InsertWhere}" Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Stretch">
                <StackPanel Margin="8,4">
                    <RadioButton x:Name="rbPrefix" Content="{DynamicResource RuleCfg_Randomize_Prefix}" GroupName="InsertWhere" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbSuffix" Content="{DynamicResource RuleCfg_Randomize_Suffix}" GroupName="InsertWhere" Margin="0,2" VerticalContentAlignment="Center"/>
                    <DockPanel Margin="0,2">
                        <RadioButton x:Name="rbPosition" Content="{DynamicResource RuleCfg_Randomize_Position}" GroupName="InsertWhere" VerticalContentAlignment="Center"/>
                        <controls:NumericUpDown x:Name="nudPosition" Width="50" MinValue="1" MaxValue="260" Value="1"
                                                HorizontalAlignment="Right"/>
                    </DockPanel>
                    <RadioButton x:Name="rbReplace" Content="{DynamicResource RuleCfg_Randomize_ReplaceCurrent}" GroupName="InsertWhere" Margin="0,2" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,8,0,0" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </StackPanel>
</UserControl>
