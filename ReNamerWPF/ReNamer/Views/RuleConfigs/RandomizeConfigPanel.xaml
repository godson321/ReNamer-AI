<UserControl x:Class="ReNamer.Views.RuleConfigs.RandomizeConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <StackPanel Margin="6">
        <GroupBox Header="{DynamicResource RuleCfg_Randomize_BasicGroup}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0" Width="Auto"
                           Text="{DynamicResource RuleCfg_Randomize_Length}"
                           Style="{DynamicResource FormLabelStyle}"
                           VerticalAlignment="Center"/>
                <controls:NumericUpDown x:Name="nudLength"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        MinValue="1"
                                        MaxValue="260"
                                        Value="8"
                                        Height="28" Margin="6"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"/>
                <CheckBox x:Name="chkUnique"
                          Grid.Row="0"
                          Grid.Column="2"
                          Content="{DynamicResource RuleCfg_Randomize_Unique}"
                          IsChecked="True" Margin="6"
                          VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0"
                           Grid.Column="3" Margin="6"
                           Text="{DynamicResource RuleCfg_Randomize_BasicHint}"
                           TextWrapping="Wrap"
                           Style="{DynamicResource DialogHintText}"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Randomize_CharactersToUse}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="chkDigits"
                          Grid.Row="0"
                          Grid.Column="0"
                          Content="{DynamicResource RuleCfg_Randomize_Digits}"
                          IsChecked="True"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkLetters"
                          Grid.Row="0"
                          Grid.Column="1"
                          Content="{DynamicResource RuleCfg_Randomize_Letters}"
                          IsChecked="True"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkUserDefined"
                          Grid.Row="0"
                          Grid.Column="2"
                          Content="{DynamicResource RuleCfg_Randomize_UserDefined}"
                          VerticalContentAlignment="Center"/>

                <TextBox x:Name="txtUserDefined"
                         Grid.Row="1"
                         Grid.ColumnSpan="3"
                         Margin="0,4,0,0"
                         VerticalAlignment="Center"
                         Style="{DynamicResource EnterpriseDialogInputTextBoxStyle}"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Randomize_CharactersHint}"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Randomize_InsertWhere}">
            <Grid Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton x:Name="rbPrefix"
                             Grid.Row="0"
                             Grid.Column="0"
                             Content="{DynamicResource RuleCfg_Randomize_Prefix}"
                             GroupName="InsertWhere"
                             IsChecked="True"
                             Margin="0,3,0,3"
                             VerticalContentAlignment="Center"/>
                <RadioButton x:Name="rbSuffix"
                             Grid.Row="0"
                             Grid.Column="1"
                             Content="{DynamicResource RuleCfg_Randomize_Suffix}"
                             GroupName="InsertWhere"
                             Margin="0,3,0,3"
                             VerticalContentAlignment="Center"/>

                <RadioButton x:Name="rbReplace"
                             Grid.Row="1"
                             Grid.Column="0"
                          Margin="0,3,0,3"
                             Content="{DynamicResource RuleCfg_Randomize_ReplaceCurrent}"
                             GroupName="InsertWhere"
                             VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension"
                          Grid.Row="1"
                          Grid.Column="1"
                          Content="{DynamicResource Config_SkipExtension}"
                          IsChecked="True"
                          Margin="0,3,0,3"
                          VerticalContentAlignment="Center"/>

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="2"
                      Margin="0,3,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="rbPosition"
                                 Grid.Column="0"
                                 Content="{DynamicResource RuleCfg_Randomize_Position}"
                                 GroupName="InsertWhere"
                                 VerticalContentAlignment="Center"/>
                    <controls:NumericUpDown x:Name="nudPosition"
                                            Grid.Column="2"
                                            MinValue="1"
                                            MaxValue="260"
                                            Value="1"
                                            Height="28"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="4"
                           Margin="0,6,0,0"
                           Text="{DynamicResource RuleCfg_Randomize_InsertHint}"
                           TextWrapping="Wrap"
                           Style="{DynamicResource DialogHintText}"/>
                </Grid>
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>
