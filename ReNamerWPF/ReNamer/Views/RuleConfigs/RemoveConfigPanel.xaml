<UserControl x:Class="ReNamer.Views.RuleConfigs.RemoveConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="440" MinHeight="280">
    <StackPanel Margin="16,12">
        <!-- Pattern: Using unified Grid layout -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Remove_Label}" Style="{DynamicResource FormLabelStyle}" VerticalAlignment="Center"/>
            <TextBox x:Name="txtPattern" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"/>
            <Button x:Name="btnSeparator" Grid.Column="2" Content="|" ToolTip="{DynamicResource RuleCfg_SeparateItems}"
                    Width="28" Height="28" Margin="4,0,0,0" FontWeight="Bold" Click="BtnSeparator_Click"/>
        </Grid>
        <!-- Options row -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource Remove_Occurrences}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <RadioButton x:Name="rbAll" Content="{DynamicResource Remove_All}" GroupName="Occurrence" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="rbFirst" Content="{DynamicResource Remove_First}" GroupName="Occurrence" Margin="0,2" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="rbLast" Content="{DynamicResource Remove_Last}" GroupName="Occurrence" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Left">
                <CheckBox x:Name="chkCaseSensitive" Content="{DynamicResource Remove_CaseSensitive}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkWholeWords" Content="{DynamicResource Remove_WholeWords}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Remove_SkipExtension}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
        <CheckBox x:Name="chkUseWildcards" Content="{DynamicResource Remove_UseWildcards}" Margin="0,4" VerticalContentAlignment="Center"/>
    </StackPanel>
</UserControl>
