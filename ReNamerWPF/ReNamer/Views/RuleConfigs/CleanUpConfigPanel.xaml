<UserControl x:Class="ReNamer.Views.RuleConfigs.CleanUpConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <StackPanel Margin="6">
        <GroupBox Header="{DynamicResource RuleCfg_CleanUp_StripBrackets}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="chkRound" Grid.Column="0" Content="(...)" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Round}" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSquare" Grid.Column="1" Content="[...]" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Square}" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkCurly" Grid.Column="2" Content="{}{...}" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Curly}" VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_CleanUp_ReplaceCharsWithSpaces}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="chkDot" Grid.Row="0" Grid.Column="0" Content="{DynamicResource RuleCfg_CleanUp_Dot}" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Dot}" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkComma" Grid.Row="0" Grid.Column="1" Content="{DynamicResource RuleCfg_CleanUp_Comma}" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Comma}" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkUnderscore" Grid.Row="0" Grid.Column="2" Content="_" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Underscore}" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkPlus" Grid.Row="1" Grid.Column="0" Content="+" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Plus}" Margin="0,2,0,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkHyphen" Grid.Row="1" Grid.Column="1" Content="-" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Hyphen}" Margin="0,2,0,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkWeb" Grid.Row="1" Grid.Column="2" Content="%20" ToolTip="{DynamicResource RuleCfg_CleanUp_Tip_Web20}" Margin="0,2,0,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipVersions"
                          Grid.Row="2"
                          Grid.ColumnSpan="3"
                          Margin="0,4,0,0"
                          Content="{DynamicResource RuleCfg_CleanUp_SkipVersions}"
                          VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_CleanUp_Section_Spacing}" Margin="0,0,0,6">
            <StackPanel Margin="6,4">
                <CheckBox x:Name="chkFixSpaces"
                          Content="{DynamicResource RuleCfg_CleanUp_FixSpaces}"
                          IsChecked="True"
                          Margin="0,0,0,2"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkNormalizeSpaces"
                          Content="{DynamicResource RuleCfg_CleanUp_NormalizeSpaces}"
                          IsChecked="True"
                          Margin="0,0,0,0"
                          VerticalContentAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_CleanUp_Section_Unicode}" Margin="0,0,0,6">
            <StackPanel Margin="6,4">
                <CheckBox x:Name="chkStripEmoji"
                          Content="{DynamicResource RuleCfg_CleanUp_StripEmoji}"
                          Margin="0,0,0,2"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkStripMarks"
                          Content="{DynamicResource RuleCfg_CleanUp_StripMarks}"
                          VerticalContentAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_CleanUp_Section_Other}">
            <StackPanel Margin="6,4">
                <CheckBox x:Name="chkCamelCase"
                          Content="{DynamicResource RuleCfg_CleanUp_CamelCase}"
                          Margin="0,0,0,2"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSharePoint"
                          Content="{DynamicResource RuleCfg_CleanUp_SharePoint}"
                          Margin="0,0,0,2"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension"
                          Content="{DynamicResource Config_SkipExtension}"
                          IsChecked="True"
                          VerticalContentAlignment="Center"/>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
