<UserControl x:Class="ReNamer.Views.RuleConfigs.CleanUpConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16,12">
        <StackPanel>
            <!-- Strip brackets -->
            <GroupBox Header="{DynamicResource RuleCfg_CleanUp_StripBrackets}" Margin="0,0,0,4" HorizontalAlignment="Stretch">
                <WrapPanel Margin="8,4">
                    <CheckBox x:Name="chkRound" Content="(...)" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkSquare" Content="[...]" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkCurly" Content="{}{...}" Margin="0,0,16,0"/>
                </WrapPanel>
            </GroupBox>
            <!-- Replace with spaces -->
            <GroupBox Header="{DynamicResource RuleCfg_CleanUp_ReplaceCharsWithSpaces}" Margin="0,0,0,4" HorizontalAlignment="Stretch">
                <StackPanel Margin="8,4">
                    <WrapPanel>
                        <CheckBox x:Name="chkDot" Content="{DynamicResource RuleCfg_CleanUp_Dot}" Margin="0,0,12,4"/>
                        <CheckBox x:Name="chkComma" Content="{DynamicResource RuleCfg_CleanUp_Comma}" Margin="0,0,12,4"/>
                        <CheckBox x:Name="chkUnderscore" Content="_" Margin="0,0,12,4"/>
                        <CheckBox x:Name="chkPlus" Content="+" Margin="0,0,12,4"/>
                        <CheckBox x:Name="chkHyphen" Content="-" Margin="0,0,12,4"/>
                        <CheckBox x:Name="chkWeb" Content="%20" Margin="0,0,12,4"/>
                    </WrapPanel>
                    <CheckBox x:Name="chkSkipVersions" Content="{DynamicResource RuleCfg_CleanUp_SkipVersions}" Margin="0,4"/>
                </StackPanel>
            </GroupBox>
            <!-- Space handling -->
            <CheckBox x:Name="chkFixSpaces" Content="{DynamicResource RuleCfg_CleanUp_FixSpaces}"
                      IsChecked="True" Margin="8,3"/>
            <CheckBox x:Name="chkNormalizeSpaces" Content="{DynamicResource RuleCfg_CleanUp_NormalizeSpaces}"
                      IsChecked="True" Margin="8,3"/>
            <!-- Unicode -->
            <CheckBox x:Name="chkStripEmoji" Content="{DynamicResource RuleCfg_CleanUp_StripEmoji}" Margin="8,3"/>
            <CheckBox x:Name="chkStripMarks" Content="{DynamicResource RuleCfg_CleanUp_StripMarks}" Margin="8,3"/>
            <!-- Other -->
            <CheckBox x:Name="chkCamelCase" Content="{DynamicResource RuleCfg_CleanUp_CamelCase}" Margin="8,3"/>
            <CheckBox x:Name="chkSharePoint" Content="{DynamicResource RuleCfg_CleanUp_SharePoint}" Margin="8,3"/>
            <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="8,3"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
