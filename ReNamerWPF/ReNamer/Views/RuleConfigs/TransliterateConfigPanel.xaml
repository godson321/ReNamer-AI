<UserControl x:Class="ReNamer.Views.RuleConfigs.TransliterateConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <GroupBox Grid.Column="0" Header="{DynamicResource RuleCfg_Transliterate_Alphabet}">
            <Grid Margin="8,6">
                <TextBox x:Name="txtAlphabet" AcceptsReturn="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         MinHeight="200" VerticalAlignment="Stretch" VerticalContentAlignment="Top" Padding="8,6,8,6" FontFamily="Consolas"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_TransliterateAlphabet}"/>
            </Grid>
        </GroupBox>
        <StackPanel Grid.Column="2">
            <GroupBox Header="{DynamicResource RuleCfg_Transliterate_Direction}" Margin="0,0,0,16">
                <StackPanel Margin="8,6">
                    <RadioButton x:Name="rbForward" Content="{DynamicResource RuleCfg_Transliterate_Forward}" GroupName="Dir" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <RadioButton x:Name="rbBackward" Content="{DynamicResource RuleCfg_Transliterate_Backward}" GroupName="Dir" Margin="0,2" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="{DynamicResource RuleCfg_Transliterate_HintTitle}" Margin="0,0,0,16">
                <TextBlock Margin="8,6" TextWrapping="Wrap"
                           Text="{DynamicResource RuleCfg_Transliterate_Hint}" Style="{DynamicResource DialogHintText}"/>
            </GroupBox>
            <GroupBox Header="{DynamicResource RuleCfg_Section_Options}">
                <StackPanel Margin="8,6">
                    <CheckBox x:Name="chkAutoCase" Content="{DynamicResource RuleCfg_Transliterate_AutoCase}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</UserControl>
