<UserControl x:Class="ReNamer.Views.RuleConfigs.TransliterateConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="440" MinHeight="280"
             Background="{DynamicResource CardBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Alphabet -->
        <StackPanel>
            <TextBlock Text="{DynamicResource RuleCfg_Transliterate_Alphabet}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="txtAlphabet" AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     Height="200" FontFamily="Consolas"
                     helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_TransliterateAlphabet}"/>
        </StackPanel>
        <!-- Options -->
        <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Stretch">
            <TextBlock Text="{DynamicResource RuleCfg_Transliterate_Direction}" Margin="0,0,0,4" Style="{DynamicResource FormLabelStyle}" VerticalAlignment="Center"/>
            <RadioButton x:Name="rbForward" Content="{DynamicResource RuleCfg_Transliterate_Forward}" GroupName="Dir" IsChecked="True" Margin="8,2" VerticalContentAlignment="Center"/>
            <RadioButton x:Name="rbBackward" Content="{DynamicResource RuleCfg_Transliterate_Backward}" GroupName="Dir" Margin="8,2" VerticalContentAlignment="Center"/>
            <TextBlock Text="{DynamicResource RuleCfg_Transliterate_HintTitle}" Margin="0,16,0,4" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap"
                       Text="{DynamicResource RuleCfg_Transliterate_Hint}" Style="{DynamicResource DialogHintText}"/>
            <CheckBox x:Name="chkAutoCase" Content="{DynamicResource RuleCfg_Transliterate_AutoCase}" IsChecked="True" Margin="0,16,0,4" VerticalContentAlignment="Center"/>
            <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,4" VerticalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
