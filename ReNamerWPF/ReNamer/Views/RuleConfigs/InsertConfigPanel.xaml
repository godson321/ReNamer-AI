<UserControl x:Class="ReNamer.Views.RuleConfigs.InsertConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <StackPanel Margin="6">
        <GroupBox Header="{DynamicResource Insert_Label}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtInsert"
                         Grid.Column="0"
                         Style="{StaticResource EnterpriseDialogInputTextBoxStyle}"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_InsertText}"/>
                <Button x:Name="btnMetaTag"
                        Grid.Column="1"
                        ToolTip="{DynamicResource Insert_MetaTag}"
                        Width="28"
                        Height="28"
                        Margin="6,0,0,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Focusable="False"
                        IsTabStop="False">
                    <Path Data="{StaticResource Icon_Insert}" Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource Insert_Where}">
            <StackPanel Margin="6,4">
                <RadioButton x:Name="rbPrefix" Content="{DynamicResource Insert_Prefix}" GroupName="InsertWhere" IsChecked="True" Margin="0,1" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="rbSuffix" Content="{DynamicResource Insert_Suffix}" GroupName="InsertWhere" Margin="0,1" VerticalContentAlignment="Center"/>

                <Grid Margin="0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="rbPosition"
                                 Grid.Column="0"
                                 Content="{DynamicResource Insert_Position}"
                                 GroupName="InsertWhere"
                                 VerticalContentAlignment="Center"/>
                    <controls:NumericUpDown x:Name="nudPosition"
                                            Grid.Column="1"
                                            MinValue="1"
                                            MaxValue="999999"
                                            Value="1"
                                            Margin="8,0,10,0"
                                            Height="28"
                                            VerticalAlignment="Center"/>
                    <CheckBox x:Name="chkRightToLeft"
                              Grid.Column="2"
                              Content="{DynamicResource Insert_RightToLeft}"
                              VerticalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="rbAfterText"
                                 Grid.Column="0"
                                 Content="{DynamicResource Insert_AfterText}"
                                 GroupName="InsertWhere"
                                 VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtAfterText"
                             Grid.Column="1"
                             Margin="8,0,0,0"
                             Style="{StaticResource EnterpriseDialogInputTextBoxStyle}"
                             helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_InsertAfterText}"/>
                </Grid>

                <Grid Margin="0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="rbBeforeText"
                                 Grid.Column="0"
                                 Content="{DynamicResource Insert_BeforeText}"
                                 GroupName="InsertWhere"
                                 VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtBeforeText"
                             Grid.Column="1"
                             Margin="8,0,0,0"
                             Style="{StaticResource EnterpriseDialogInputTextBoxStyle}"
                             helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_InsertBeforeText}"/>
                </Grid>

                <RadioButton x:Name="rbReplaceName" Content="{DynamicResource Insert_ReplaceCurrentName}" GroupName="InsertWhere" Margin="0,1" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,6,0,0" VerticalContentAlignment="Center"/>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
