<UserControl x:Class="ReNamer.Views.RuleConfigs.ReformatDateConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="{DynamicResource RuleCfg_ReformatDate_FormatGroup}">
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Width="Auto" Text="{DynamicResource RuleCfg_ReformatDate_FindFormats}" Style="{DynamicResource FormLabelStyle}" VerticalAlignment="Center"/>
                <ComboBox x:Name="cboSourceFormat" Grid.Row="0" Grid.Column="1" IsEditable="True" HorizontalAlignment="Stretch"
                          helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_ReformatDateSource}">
                    <ComboBoxItem Content="yyyy-MM-dd"/>
                    <ComboBoxItem Content="dd.MM.yyyy"/>
                    <ComboBoxItem Content="MM-dd-yyyy"/>
                    <ComboBoxItem Content="yyyyMMdd"/>
                    <ComboBoxItem Content="dd MMM yyyy"/>
                    <ComboBoxItem Content="yyyy-MM-dd HH:mm:ss"/>
                </ComboBox>
                <Button x:Name="btnHelp" Grid.Row="0" Grid.Column="2" Margin="8,0,0,0"
                        Content="{DynamicResource RuleCfg_ReformatDate_FormatHelp}"
                        FontSize="11" Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="8,3" Click="BtnHelp_Click"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Width="Auto" Text="{DynamicResource RuleCfg_ReformatDate_ConvertTo}" Style="{DynamicResource FormLabelStyle}" VerticalAlignment="Center"/>
                <ComboBox x:Name="cboTargetFormat" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" IsEditable="True" HorizontalAlignment="Stretch"
                          helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_ReformatDate_FormatHint}">
                    <ComboBoxItem Content="yyyy-MM-dd"/>
                    <ComboBoxItem Content="dd.MM.yyyy"/>
                    <ComboBoxItem Content="MM-dd-yyyy"/>
                    <ComboBoxItem Content="yyyyMMdd"/>
                    <ComboBoxItem Content="dd MMM yyyy"/>
                    <ComboBoxItem Content="yyyy-MM-dd HH:mm:ss"/>
                </ComboBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="{DynamicResource RuleCfg_ReformatDate_OptionsGroup}">
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <CheckBox x:Name="chkWholeWords" Content="{DynamicResource RuleCfg_ReformatDate_WholeWords}" IsChecked="True" Margin="0,0,16,0" VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="2" HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="chkCustomShortMonths" Grid.Row="0" Content="{DynamicResource RuleCfg_ReformatDate_CustomShortMonths}" VerticalContentAlignment="Center"/>
                    <ComboBox x:Name="cboCustomShortMonths" Grid.Row="0" Grid.Column="2" Width="220" IsEditable="True" HorizontalAlignment="Left"
                              helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_ReformatDateShortMonths}"/>
                    <CheckBox x:Name="chkCustomLongMonths" Grid.Row="2" Content="{DynamicResource RuleCfg_ReformatDate_CustomLongMonths}" VerticalContentAlignment="Center"/>
                    <ComboBox x:Name="cboCustomLongMonths" Grid.Row="2" Grid.Column="2" Width="220" IsEditable="True" HorizontalAlignment="Left"
                              helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_ReformatDateLongMonths}"/>
                </Grid>

                <TextBlock Grid.Row="4" Text="{DynamicResource RuleCfg_ReformatDate_CustomMonthsHint}"
                           TextWrapping="Wrap" Style="{DynamicResource DialogHintText}"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="{DynamicResource RuleCfg_ReformatDate_AdjustGroup}">
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="chkAdjustTime" Grid.Row="0" Grid.Column="0" Content="{DynamicResource RuleCfg_ReformatDate_AdjustBy}" VerticalContentAlignment="Center"/>
                <controls:NumericUpDown x:Name="nudAdjustBy" Grid.Row="0" Grid.Column="1" MinValue="-1000000" MaxValue="1000000" HorizontalAlignment="Left" Margin="8,0,0,0"/>
                <ComboBox x:Name="cboTimePart" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Left" Margin="8,0,0,0">
                    <ComboBoxItem Content="{DynamicResource RuleCfg_ReformatDate_UnitHours}" IsSelected="True"/>
                    <ComboBoxItem Content="{DynamicResource RuleCfg_ReformatDate_UnitMinutes}"/>
                    <ComboBoxItem Content="{DynamicResource RuleCfg_ReformatDate_UnitSeconds}"/>
                    <ComboBoxItem Content="{DynamicResource RuleCfg_ReformatDate_UnitDays}"/>
                    <ComboBoxItem Content="{DynamicResource RuleCfg_ReformatDate_UnitMonths}"/>
                    <ComboBoxItem Content="{DynamicResource RuleCfg_ReformatDate_UnitYears}"/>
                </ComboBox>
                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="5,0,0,0" Text="{DynamicResource RuleCfg_ReformatDate_AdjustHint}" TextWrapping="Wrap" Style="{DynamicResource DialogHintText}"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
