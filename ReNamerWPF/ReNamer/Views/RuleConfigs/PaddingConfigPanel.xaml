<UserControl x:Class="ReNamer.Views.RuleConfigs.PaddingConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <StackPanel Margin="6">
        <GroupBox Header="{DynamicResource RuleCfg_Padding_NumberSequences}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="84"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="chkAddZeroPadding"
                              Grid.Column="0"
                              Content="{DynamicResource RuleCfg_Padding_AddZeroPadding}"
                              VerticalContentAlignment="Center"/>
                    <controls:NumericUpDown x:Name="nudZeroPadLength"
                                            Grid.Column="2"
                                            MinValue="1"
                                            MaxValue="260"
                                            Value="1"
                                            Height="28"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                </Grid>

                <CheckBox x:Name="chkRemoveZeroPadding"
                          Grid.Row="1"
                          Margin="0,4,0,0"
                          Content="{DynamicResource RuleCfg_Padding_RemoveZeroPadding}"
                          VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Padding_TextPadding}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="chkAddTextPadding"
                              Grid.Column="0"
                              Content="{DynamicResource RuleCfg_Padding_AddTextPadding}"
                              VerticalContentAlignment="Center"/>
                    <controls:NumericUpDown x:Name="nudTextPadLength"
                                            Grid.Column="2"
                                            MinValue="1"
                                            MaxValue="260"
                                            Value="1"
                                            Height="28"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPadChars"
                             Grid.Column="4"
                             VerticalAlignment="Center"
                             Style="{StaticResource EnterpriseDialogInputTextBoxStyle}"
                             helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_PaddingChars}"/>

                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6,6,0,6"
                               Text="{DynamicResource RuleCfg_Padding_Position}"
                               Style="{DynamicResource FormLabelStyle}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right"/>
                    <StackPanel Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="3"
                                Orientation="Horizontal"  Margin="0,6,6,6"
                                VerticalAlignment="Center">
                        <RadioButton x:Name="rbLeft" Grid.Row="1"
                                     Content="{DynamicResource RuleCfg_Padding_Left}"
                                     GroupName="PadPos"
                                     IsChecked="True"
                                     Margin="0,0,12,0"
                                     VerticalContentAlignment="Center"/>
                        <RadioButton x:Name="rbRight"
                                     Content="{DynamicResource RuleCfg_Padding_Right}"
                                     GroupName="PadPos"
                                     VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Section_Options}">
            <Grid Margin="6,4">
                <CheckBox x:Name="chkSkipExtension"
                          Content="{DynamicResource Config_SkipExtension}"
                          IsChecked="True"
                          VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>
