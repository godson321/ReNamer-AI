<UserControl x:Class="ReNamer.Views.RuleConfigs.RearrangeConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <StackPanel Margin="6">
        <GroupBox Header="{DynamicResource RuleCfg_Rearrange_SplitUsing}" Margin="0,0,0,6">
            <Grid Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton x:Name="rbDelimiters"
                             Grid.Row="0"
                             Grid.Column="0"
                             Content="{DynamicResource RuleCfg_Rearrange_DelimiterMode}"
                             GroupName="Split"
                             IsChecked="True"
                             VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{DynamicResource RuleCfg_Rearrange_SplitHint_Delimiters}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Style="{DynamicResource DialogHintText}"/>

                <RadioButton x:Name="rbPositions"
                             Grid.Row="1"
                             Grid.Column="0"
                             Margin="0,4,0,4"
                             Content="{DynamicResource RuleCfg_Rearrange_Positions}"
                             GroupName="Split"
                             VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,4,0,0"
                           Text="{DynamicResource RuleCfg_Rearrange_SplitHint_Positions}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Style="{DynamicResource DialogHintText}"/>

                <RadioButton x:Name="rbExact"
                             Grid.Row="2"
                             Grid.Column="0"
                             Margin="0,4,0,4"
                             Content="{DynamicResource RuleCfg_Rearrange_ExactPattern}"
                             GroupName="Split"
                             VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,4,0,0"
                           Text="{DynamicResource RuleCfg_Rearrange_SplitHint_ExactPattern}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Style="{DynamicResource DialogHintText}"/>

                <Grid Grid.Row="3" Grid.ColumnSpan="3" Margin="0,6,6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,6,0,0"
                       Text="{DynamicResource RuleCfg_Rearrange_Delimiters}"
                       Style="{DynamicResource FormLabelStyle}"
                       VerticalAlignment="Center"/>
                    <TextBox x:Name="txtDelimiters"
                     Grid.Row="0"
                     Grid.Column="2"
                     Style="{DynamicResource EnterpriseDialogInputTextBoxStyle}"
                     VerticalAlignment="Center"
                     helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_RearrangeDelimiters}"/>
                    <Button x:Name="btnDelimSeparator"
                    Grid.Row="0"
                    Grid.Column="4"
                    Width="28"
                    Height="28"
                    Padding="0"
                    ToolTip="{DynamicResource RuleCfg_Rearrange_SeparatorTip}"
                    Click="BtnDelimSeparator_Click"
                    Focusable="False"
                    IsTabStop="False">
                        <Path Data="{StaticResource Icon_Columns}"
                      Fill="{DynamicResource TextSecondaryBrush}"
                      Width="14"
                      Height="14"
                      Stretch="Uniform"/>
                    </Button>

                    <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,6,0,0"
                       Text="{DynamicResource RuleCfg_Rearrange_NewPattern}"
                       Style="{DynamicResource FormLabelStyle}"
                       VerticalAlignment="Center"/>
                    <TextBox x:Name="txtNewPattern"
                     Grid.Row="1"
                     Grid.Column="2"
                     Margin="0,6,0,0"
                     Style="{DynamicResource EnterpriseDialogInputTextBoxStyle}"
                     VerticalAlignment="Center"
                     helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_RearrangeNewPattern}"/>
                    <Button x:Name="btnPatternMetaTag"
                    Grid.Row="1"
                    Grid.Column="4"
                    Margin="0,6,0,0"
                    Width="28"
                    Height="28"
                    Padding="0"
                    ToolTip="{DynamicResource RuleCfg_Rearrange_MetaTagTip}"
                    Click="BtnPatternMetaTag_Click"
                    Focusable="False"
                    IsTabStop="False">
                        <Path Data="{StaticResource Icon_Options}"
                      Fill="{DynamicResource TextSecondaryBrush}"
                      Width="14"
                      Height="14"
                      Stretch="Uniform"/>
                    </Button>
                </Grid>

                <TextBlock Margin="20,6,6,6" Grid.Row="4" Grid.ColumnSpan="3" 
                   TextWrapping="Wrap"
                   Text="{DynamicResource RuleCfg_Rearrange_Hint}"
                   Style="{DynamicResource DialogHintText}"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Section_Options}">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="chkSkipExtension"
                          Grid.Column="0"
                          Content="{DynamicResource Config_SkipExtension}"
                          IsChecked="True"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkRightToLeft"
                          Grid.Column="1"
                          Content="{DynamicResource Config_RightToLeft}"
                          VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>
