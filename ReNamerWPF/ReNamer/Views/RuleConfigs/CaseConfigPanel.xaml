<UserControl x:Class="ReNamer.Views.RuleConfigs.CaseConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             MinWidth="500" MinHeight="280"
             Background="{DynamicResource CardBrush}">
    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="{DynamicResource Case_Composite_Title}">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Case_Composite_FirstLetter}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbFirstMode" SelectedIndex="0" SelectionChanged="CmbFirstMode_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Keep}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Upper}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Lower}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_PinyinFirst}"/>
                    </ComboBox>
                    <StackPanel x:Name="pnlPinyinOptions" Margin="0,6,0,0">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Case_Composite_PinyinIndex}" VerticalAlignment="Center"/>
                            <controls:NumericUpDown x:Name="nudPinyinIndex" Grid.Column="1" Width="50" MinValue="1" MaxValue="99" Value="1" Margin="8,0,0,0"/>
                        </Grid>
                        <ComboBox x:Name="cmbPinyinCase" SelectedIndex="0" Margin="0,0,0,4">
                            <ComboBoxItem Content="{DynamicResource Case_Composite_Upper}"/>
                            <ComboBoxItem Content="{DynamicResource Case_Composite_Lower}"/>
                        </ComboBox>
                        <ComboBox x:Name="cmbPinyinAction" SelectedIndex="0">
                            <ComboBoxItem Content="{DynamicResource Case_Composite_PinyinInsert}"/>
                            <ComboBoxItem Content="{DynamicResource Case_Composite_PinyinReplace}"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource Case_Composite_RemainingLetters}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbRestMode" SelectedIndex="0">
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Keep}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_AllUpper}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_AllLower}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_CapitalizeWords}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Invert}"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="{DynamicResource Case_Composite_Extension}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbExtMode" SelectedIndex="0">
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Keep}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Lower}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Upper}"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="{DynamicResource RuleCfg_Section_Options}" Margin="0,8,0,0">
            <StackPanel Margin="8,6">
                <CheckBox x:Name="chkPreserveCase" Content="{DynamicResource Case_PreserveCase}" Margin="0,2" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkForceCase" Content="{DynamicResource Case_ForceCase}" Margin="0,2,0,4" VerticalContentAlignment="Center"/>
                <TextBox x:Name="txtForceCase" Margin="24,0,0,0" VerticalAlignment="Center"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_CaseForceCase}"/>
                <TextBlock Text="{DynamicResource Case_ForceCaseHint}" TextWrapping="Wrap" Margin="24,4,0,6" Style="{DynamicResource DialogHintText}"/>
                <CheckBox x:Name="chkSkipExtension" Content="{DynamicResource Config_SkipExtension}" IsChecked="True" Margin="0,2" VerticalContentAlignment="Center"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
