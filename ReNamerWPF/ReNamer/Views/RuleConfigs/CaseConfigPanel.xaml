<UserControl x:Class="ReNamer.Views.RuleConfigs.CaseConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ReNamer.Controls"
             xmlns:helpers="clr-namespace:ReNamer.Helpers"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d"
             MinWidth="0"
             MinHeight="0"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             HorizontalAlignment="Stretch"
             Background="{DynamicResource CardBrush}">
    <UserControl.Resources>
        <Style x:Key="CasePinyinChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF4FF"/>
            <Setter Property="BorderBrush" Value="#C7D7FE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="7,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CasePinyinChipTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogLabelText}">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="6">
            <GroupBox Header="{DynamicResource Case_Composite_Title}">
                <Grid Margin="6,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{DynamicResource Case_Composite_FirstLetter}" Style="{DynamicResource DialogLabelText}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbFirstMode"
                              SelectedIndex="0"
                              Style="{DynamicResource EnterpriseDialogInputComboBoxStyle}"
                              SelectionChanged="CmbFirstMode_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Keep}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Upper}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Lower}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_PinyinFirst}"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="{DynamicResource Case_Composite_RemainingLetters}" Style="{DynamicResource DialogLabelText}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbRestMode"
                              SelectedIndex="0"
                              Style="{DynamicResource EnterpriseDialogInputComboBoxStyle}">
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Keep}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_AllUpper}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_AllLower}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_CapitalizeWords}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Invert}"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4">
                    <TextBlock Text="{DynamicResource Case_Composite_Extension}" Style="{DynamicResource DialogLabelText}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbExtMode"
                              SelectedIndex="0"
                              Style="{DynamicResource EnterpriseDialogInputComboBoxStyle}">
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Keep}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Lower}"/>
                        <ComboBoxItem Content="{DynamicResource Case_Composite_Upper}"/>
                    </ComboBox>
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="5"
                        x:Name="pinyinOptionsHost"
                        Margin="0,6,0,0"
                        MaxHeight="0"
                        Opacity="0"
                        ClipToBounds="True">
                    <Grid x:Name="pnlPinyinOptions">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CasePinyinChipStyle}">
                                <TextBlock Text="{DynamicResource RuleCfg_Case_PinyinIndexPrefix}" Style="{StaticResource CasePinyinChipTextStyle}"/>
                            </Border>
                            <controls:NumericUpDown x:Name="nudPinyinIndex"
                                                    Grid.Column="1"
                                                    Height="28"
                                                    Margin="6,0"
                                                    VerticalAlignment="Center"
                                                    MinValue="1"
                                                    MaxValue="99"
                                                    Value="1"/>
                            <Border Grid.Column="2" Style="{StaticResource CasePinyinChipStyle}">
                                <TextBlock Text="{DynamicResource RuleCfg_Case_PinyinIndexSuffix}" Style="{StaticResource CasePinyinChipTextStyle}"/>
                            </Border>
                        </Grid>

                        <ComboBox Grid.Column="1"
                                  x:Name="cmbPinyinCase"
                                  SelectedIndex="0"
                                  Margin="6,0,0,0"
                                  MinWidth="112"
                                  VerticalAlignment="Center"
                                  Style="{DynamicResource EnterpriseDialogInputComboBoxStyle}">
                            <ComboBoxItem Content="{DynamicResource Case_Composite_Upper}"/>
                            <ComboBoxItem Content="{DynamicResource Case_Composite_Lower}"/>
                        </ComboBox>

                        <ComboBox Grid.Column="2"
                                  x:Name="cmbPinyinAction"
                                  SelectedIndex="0"
                                  Margin="6,0,0,0"
                                  MinWidth="112"
                                  VerticalAlignment="Center"
                                  Style="{DynamicResource EnterpriseDialogInputComboBoxStyle}">
                            <ComboBoxItem Content="{DynamicResource Case_Composite_PinyinInsert}"/>
                            <ComboBoxItem Content="{DynamicResource Case_Composite_PinyinReplace}"/>
                        </ComboBox>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Case_ForceCaseGroup}">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="chkPreserveCase"
                          Grid.Row="0"
                          Grid.ColumnSpan="2"
                          Content="{DynamicResource Case_PreserveCase}"
                          Margin="0,0,0,1"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkForceCase"
                          Grid.Row="1"
                          Content="{DynamicResource Case_ForceCase}"
                          VerticalContentAlignment="Center"/>
                <TextBox x:Name="txtForceCase"
                         Grid.Row="1"
                         Grid.Column="1"
                         VerticalContentAlignment="Center"
                         Style="{DynamicResource EnterpriseDialogInputTextBoxStyle}"
                         helpers:PlaceholderBehavior.Placeholder="{DynamicResource RuleCfg_Placeholder_CaseForceCase}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{DynamicResource Case_ForceCaseHint}"
                           TextWrapping="Wrap"
                           Margin="0,1,0,0"
                           Style="{DynamicResource DialogHintText}"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="{DynamicResource RuleCfg_Case_ExtensionGroup}">
            <Grid Margin="6,4">
                <CheckBox x:Name="chkSkipExtension"
                          Content="{DynamicResource Config_SkipExtension}"
                          IsChecked="True"
                          VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>
