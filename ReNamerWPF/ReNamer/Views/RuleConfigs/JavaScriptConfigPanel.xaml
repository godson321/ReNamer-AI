<UserControl x:Class="ReNamer.Views.RuleConfigs.JavaScriptConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="560" MinHeight="300"
             Background="{DynamicResource CardBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtStatus"
                   Grid.Row="0"
                   Margin="4,0,4,6"
                   Foreground="{DynamicResource TextBrush}"
                   TextWrapping="Wrap" />

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <DataGrid x:Name="dgScripts"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      MouseDoubleClick="ScriptsGrid_MouseDoubleClick"
                      Background="{DynamicResource TextBoxBrush}"
                      Foreground="{DynamicResource TextBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="脚本" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="大小(KB)" Binding="{Binding SizeKb}" Width="*" />
                    <DataGridTextColumn Header="修改时间" Binding="{Binding LastWriteTime}" Width="1.6*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="btnReload"
                    Content="刷新列表"
                    MinWidth="88"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="Reload_Click"
                    Margin="3"/>
            <Button x:Name="btnOpenFolder"
                    Content="打开脚本目录"
                    MinWidth="96"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="OpenFolder_Click"
                    Margin="3"/>
            <Button x:Name="btnValidate"
                    Content="{DynamicResource JavaScript_Validate}"
                    MinWidth="72"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="Validate_Click"
                    Margin="3"/>
            <Button x:Name="btnHelp"
                    Content="{DynamicResource JavaScript_Help}"
                    MinWidth="72"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="Help_Click"
                    Margin="3"/>
        </StackPanel>
    </Grid>
</UserControl>
