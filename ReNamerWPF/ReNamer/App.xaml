<Application x:Class="ReNamer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 设计系统 -->
                <ResourceDictionary Source="Resources/DesignSystemResources.xaml"/>
                <!-- 全局主题 -->
                <ResourceDictionary Source="Themes/Theme.xaml"/>
                <!-- 矢量图标 -->
                <ResourceDictionary Source="Resources/Icons/IconResources.xaml"/>
                <!-- 默认加载中文资源 -->
                <ResourceDictionary Source="Resources/Strings.zh-CN.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
