    object N1: TMenuItem
      Caption = '-'
    end
    object MI_SelectAll: TMenuItem
      Caption = 'Select All'
      OnClick = MI_SelectAllClick
    end
    object MI_InvertSelection: TMenuItem
      Caption = 'Invert Selection'
      OnClick = MI_InvertSelectionClick
    end
  end

  object MainMenu: TMainMenu
    Left = 50
    Top = 200
    object MenuItem_File: TMenuItem
      Caption = '&File'
      object MI_AddFiles: TMenuItem
        Caption = 'Add &Files...'
        OnClick = ToolButton_AddFilesClick
      end
      object MI_AddFolders: TMenuItem
        Caption = 'Add F&olders...'
        OnClick = ToolButton_AddFoldersClick
      end
      object N2: TMenuItem
        Caption = '-'
      end
      object MI_Preview: TMenuItem
        Caption = '&Preview'
