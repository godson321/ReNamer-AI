      end
      object MI_RemoveRule: TMenuItem
        Caption = '&Remove Rule'
        OnClick = ToolButton_RemoveRuleClick
      end
    end
    object MenuItem_Help: TMenuItem
      Caption = '&Help'
      object MI_About: TMenuItem
        Caption = '&About'
        OnClick = MI_AboutClick
      end
    end
  end

  object OpenDialog: TOpenDialog
    Title = 'Add Files'
    Filter = 'All Files (*.*)|*.*'
    Options = [ofAllowMultiSelect, ofFileMustExist]
    Left = 100
    Top = 200
  end

  object SelectDirectoryDialog: TSelectDirectoryDialog
    Title = 'Select Folder'
