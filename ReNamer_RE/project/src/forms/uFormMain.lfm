object Form_Main: TForm_Main
  Left = 300
  Height = 500
  Top = 150
  Width = 750
  AllowDropFiles = True
  Caption = 'ReNamer Clone'
  ClientHeight = 500
  ClientWidth = 750
  KeyPreview = True
  Menu = MainMenu
  OnClose = FormClose
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  OnDropFiles = FormDropFiles
  OnShow = FormShow
  Position = poScreenCenter
  LCLVersion = '3.0.0.0'

  object ToolBar_Main: TToolBar
    Left = 0
    Height = 38
    Top = 0
    Width = 750
    AutoSize = True
    ButtonHeight = 36
    ButtonWidth = 80
    EdgeBorders = [ebBottom]
    List = True
    ShowCaptions = True
    TabOrder = 0
    object ToolButton_AddFiles: TToolButton
      Left = 1
      Top = 0
      Caption = 'Add Files'
      OnClick = ToolButton_AddFilesClick
    end
    object ToolButton_AddFolders: TToolButton
      Left = 81
      Top = 0
      Caption = 'Add Folders'
      OnClick = ToolButton_AddFoldersClick
    end
    object ToolButton_Sep1: TToolButton
      Left = 161
      Top = 0
      Width = 8
      Style = tbsSeparator
    end
    object ToolButton_Preview: TToolButton
      Left = 169
      Top = 0
      Caption = 'Preview'
      OnClick = ToolButton_PreviewClick
    end
    object ToolButton_Rename: TToolButton
      Left = 249
      Top = 0
      Caption = 'Rename'
      OnClick = ToolButton_RenameClick
    end
  end

  object Panel_Main: TPanel
    Left = 0
    Height = 437
    Top = 38
    Width = 750
    Align = alClient
    BevelOuter = bvNone
    TabOrder = 1

    object Panel_Rules: TPanel
      Left = 0
      Height = 437
      Top = 0
      Width = 250
      Align = alLeft
      BevelOuter = bvNone
      TabOrder = 0

      object ToolBar_Rules: TToolBar
        Left = 0
        Height = 26
        Top = 0
        Width = 250
        AutoSize = True
        ButtonHeight = 24
        ButtonWidth = 60
        EdgeBorders = [ebBottom]
        List = True
        ShowCaptions = True
        TabOrder = 0
        object ToolButton_AddRule: TToolButton
          Left = 1
          Top = 0
          Caption = 'Add'
          OnClick = ToolButton_AddRuleClick
        end
        object ToolButton_RemoveRule: TToolButton
          Left = 61
          Top = 0
          Caption = 'Remove'
          OnClick = ToolButton_RemoveRuleClick
        end
        object ToolButton_MoveUpRule: TToolButton
          Left = 121
          Top = 0
          Caption = 'Up'
          OnClick = ToolButton_MoveUpRuleClick
        end
        object ToolButton_MoveDownRule: TToolButton
          Left = 181
          Top = 0
          Caption = 'Down'
          OnClick = ToolButton_MoveDownRuleClick
        end
      end

      object ListView_Rules: TListView
        Left = 0
        Height = 411
        Top = 26
        Width = 250
        Align = alClient
        Checkboxes = True
        Columns = <
          item
            Caption = 'Rule'
            Width = 180
          end
          item
            Caption = 'Description'
            Width = 300
          end>
        ReadOnly = True
        RowSelect = True
        TabOrder = 1
        ViewStyle = vsReport
        OnDblClick = ListView_RulesDblClick
      end
    end

    object Splitter_Middle: TSplitter
      Left = 250
      Height = 437
      Top = 0
      Width = 5
      ResizeAnchor = akLeft
    end

    object Panel_Files: TPanel
      Left = 255
      Height = 437
      Top = 0
      Width = 495
      Align = alClient
      BevelOuter = bvNone
      TabOrder = 1

      object ToolBar_Files: TToolBar
        Left = 0
        Height = 26
        Top = 0
        Width = 495
        AutoSize = True
        ButtonHeight = 24
        ButtonWidth = 60
        EdgeBorders = [ebBottom]
        List = True
        ShowCaptions = True
        TabOrder = 0
        object ToolButton_ClearFiles: TToolButton
          Left = 1
          Top = 0
          Caption = 'Clear'
          OnClick = ToolButton_ClearFilesClick
        end
        object ToolButton_Sep2: TToolButton
          Left = 61
          Top = 0
          Width = 8
          Style = tbsSeparator
        end
        object ToolButton_Sorting: TToolButton
          Left = 69
          Top = 0
          Caption = 'Sort'
          OnClick = ToolButton_SortingClick
        end
      end

      object ListView_Files: TListView
        Left = 0
        Height = 411
        Top = 26
        Width = 495
        Align = alClient
        Columns = <
          item
            Caption = '#'
            Width = 40
          end
          item
            Caption = 'Original Name'
            Width = 180
          end
          item
            Caption = 'New Name'
            Width = 180
          end
          item
            AutoSize = True
            Caption = 'Path'
          end>
        MultiSelect = True
        ReadOnly = True
        RowSelect = True
        PopupMenu = PM_Files
        TabOrder = 1
        ViewStyle = vsReport
      end
    end
  end

  object StatusBar: TStatusBar
    Left = 0
    Height = 25
    Top = 475
    Width = 750
    Panels = <
      item
        Text = 'Files: 0'
        Width = 120
      end
      item
        Text = 'Rules: 0'
        Width = 120
      end
      item
        Text = 'Ready'
        Width = 200
      end>
  end

  object PM_Files: TPopupMenu
