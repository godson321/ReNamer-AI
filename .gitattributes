# Default: normalize text and keep LF unless explicitly overridden.
* text=auto

# Windows desktop project files use CRLF to match Visual Studio defaults.
*.cs text eol=crlf
*.xaml text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.resx text eol=crlf
*.config text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Keep typical Unix scripts in LF.
*.sh text eol=lf
